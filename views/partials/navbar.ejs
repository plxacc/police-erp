<div class="navbar">
  <h2>القيادة العامة للشرطة</h-rules" class="nav-link-main">قوانين المواطنين</a>  <h2>القيادة العامة للشرطة</h2>

    <% if (!user) { %>
      <a href="/login" class="nav-link-action">التقديم للشرطة</a>
    <% } else if (!user.perms.isPolice) { %>
      <a href="/jobs" class="nav-link-action">التقديم للشرطة</a>
    <% } %>

    <% if (user && user.perms.isPolice) { %>
      <a href="/police-rules" class="nav-link-main">قوانين العسكر</a>
      <a href="/armory" class="nav-link-main">العهدة العسكرية</a>
      <a href="/certificates" class="nav-link-main">الشهادات والرخص</a>
    <% } %>

    <% if (user && (user.perms.isTrainer || user.perms.isOfficer || user.perms.isAcademyManager)) { %>
      <a href="/admin" class="nav-link-warn">التقديمات</a>
      <a href="/academy" class="nav-link-info">الأكاديمية العسكرية</a>
    <% } %>

    <% if (user && (user.perms.isOfficer || user.perms.isCertManager)) { %>
      <a href="/system/certificates" class="nav-link-success">إدارة الشهادات</a>
    <% } %>

    <% if (user && user.perms.isOfficer) { %>
      <a href="/system" class="nav-link-danger">إدارة النظام</a>
    <% } %>
  </div>

  <div class="user-box">
    <% if (user) { %>
      <a href="/system/personnel/<%= user.id %>" class="user-card">
        <div class="user-name"><%= user.realName || user.username %></div>

        <% if (user.perms.isPolice) { %>
          <div class="user-rank">
            <%= user.customRank %> •
            <%= user.perms.isOfficer ? 'ضابط' :
                user.perms.isAcademyManager ? 'إدارة أكاديمية' :
                user.perms.isTrainer ? 'مدرب' :
                user.perms.isNCO ? 'ضابط صف' : 'فرد' %>
          </div>
        <% } else { %>
          <div class="user-rank"><%= user.perms.isActivated ? 'مفعل' : 'غير مفعل' %></div>
        <% } %>
      </a>

      <a href="/logout" class="logout-btn">خروج</a>
    <% } else { %>
      <a href="/login" class="btn-primary">تسجيل الدخول</a>
    <% } %>
  </div>
</div>

<div class="toast-container" id="toast-container">
  <% if (typeof notifications !== 'undefined' && notifications.length > 0) { %>
    <% notifications.forEach(notif => { %>
      <div class="toast <%= notif.type %>"><%= notif.message %></div>
    <% }) %>
  <% } %>
</div>

<script>
  document.querySelectorAll('.toast').forEach(t => {
    setTimeout(() => {
      t.style.opacity = '0';
      setTimeout(() => t.remove(), 400);
    }, 6000);
  });
</script>

