<!DOCTYPE html>
<html lang="ar">
<head>
    <meta charset="UTF-8">
    <title>إدارة التقديمات والأكاديمية</title>
    <link rel="stylesheet" href="/style.css">
    <style>
        .app-card { background: rgba(0,0,0,0.5); padding: 20px; border-radius: 10px; margin-bottom: 20px; border-right: 5px solid var(--primary); }
        .info-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 10px; margin-bottom: 15px; background: rgba(255,255,255,0.05); padding: 15px; border-radius: 8px; }
        .info-item { color: white; font-size: 14px; }
        .info-item span { color: var(--warning); font-weight: bold; }
        .grade-input { width: 60px; padding: 5px; background: #222; border: 1px solid var(--warning); color: white; text-align: center; border-radius: 5px; }
    </style>
</head>
<body>
    <%- include('partials/navbar') %>
    <div class="container fade-in">
        <a href="/system" class="btn-secondary" style="margin-bottom: 20px;">⬅️ العودة للوحة المركزية</a>
        <h1 style="text-align:center; color:var(--warning); margin-bottom: 30px;">📋 إدارة التجنيد وأكاديمية الشرطة</h1>

        <% 
        let newApps = []; let academyApps = [];
        Object.entries(db).forEach(([id, app]) => {
            if (app.status === 'applied') newApps.push({ id, ...app });
            else if (app.status === 'academy') academyApps.push({ id, ...app });
        });
        %>

        <h2 style="color: #9B59B6; border-bottom: 2px solid #9B59B6; padding-bottom: 10px;">🎓 الأكاديمية العسكرية (<%= academyApps.length %> متدرب)</h2>
        <% if (academyApps.length === 0) { %>
            <p style="color: gray; margin-bottom: 40px;">لا يوجد متدربين في الأكاديمية حالياً.</p>
        <% } else { %>
            <% academyApps.forEach(app => { %>
                <div class="app-card" style="border-right-color: #9B59B6;">
                    <div style="display:flex; justify-content:space-between;">
                        <h3 style="color: white; margin-bottom: 10px;">👤 المتدرب: <%= app.personalInfo?.realName || app.username %></h3>
                        <% if (app.grades) { %>
                            <span style="background: rgba(46, 204, 113, 0.2); border: 1px solid var(--success); padding: 5px 15px; border-radius: 5px; color: var(--success); font-weight:bold;">الدرجة: <%= app.grades.total %> / 80</span>
                        <% } else { %>
                            <span style="background: rgba(231, 76, 60, 0.2); border: 1px solid var(--danger); padding: 5px 15px; border-radius: 5px; color: var(--danger); font-weight:bold;">لم يتم التقييم</span>
                        <% } %>
                    </div>
                    
                    <div class="info-grid">
                        <div class="info-item">الهوية: <span><%= app.personalInfo?.nationalId || 'غير متوفر' %></span></div>
                        <div class="info-item">العمر: <span><%= app.personalInfo?.age || 'غير متوفر' %></span></div>
                        <div class="info-item">رقم الهاتف: <span><%= app.personalInfo?.phone || 'غير متوفر' %></span></div>
                        <div class="info-item">الديسكورد: <span><%= app.username %></span></div>
                    </div>

                    <% if (perms.canGrade) { %>
                        <form action="/admin/grade" method="POST" style="background: rgba(241, 196, 15, 0.1); padding: 15px; border-radius: 8px; margin-bottom: 15px; border: 1px dashed var(--warning);">
                            <h4 style="color: var(--warning); margin-bottom: 10px;">📝 رصد درجات الدورة (المدربين)</h4>
                            <input type="hidden" name="userId" value="<%= app.id %>">
                            <div style="display: flex; gap: 15px; flex-wrap: wrap; align-items: center;">
                                <div><label style="color:white; font-size:12px;">الاستيقافات (20)</label><br><input type="number" name="stops" max="20" min="0" required class="grade-input" value="<%= app.grades?.stops || '' %>"></div>
                                <div><label style="color:white; font-size:12px;">مركز العمليات (20)</label><br><input type="number" name="ops" max="20" min="0" required class="grade-input" value="<%= app.grades?.ops || '' %>"></div>
                                <div><label style="color:white; font-size:12px;">التفاوض (20)</label><br><input type="number" name="neg" max="20" min="0" required class="grade-input" value="<%= app.grades?.neg || '' %>"></div>
                                <div><label style="color:white; font-size:12px;">أسئلة عامة (10)</label><br><input type="number" name="general" max="10" min="0" required class="grade-input" value="<%= app.grades?.general || '' %>"></div>
                                <div><label style="color:white; font-size:12px;">حضور الحصة 1 (5)</label><br><input type="number" name="att1" max="5" min="0" required class="grade-input" value="<%= app.grades?.att1 || '' %>"></div>
                                <div><label style="color:white; font-size:12px;">حضور الحصة 2 (5)</label><br><input type="number" name="att2" max="5" min="0" required class="grade-input" value="<%= app.grades?.att2 || '' %>"></div>
                                <div style="margin-top: 18px;"><button type="submit" class="btn-warning" style="color:black; font-weight:bold; padding: 6px 15px;">حفظ الدرجات 💾</button></div>
                            </div>
                        </form>
                    <% } %>

                    <div style="display:flex; gap:10px;">
                        <% if (perms.canFinalAccept) { %>
                            <form action="/admin/enlist" method="POST" onsubmit="return confirm('هل أنت متأكد من تجنيد الفرد نهائياً وإصدار كود عسكري له؟');">
                                <input type="hidden" name="userId" value="<%= app.id %>"><button type="submit" class="btn-success">تجنيد نهائي (مستجد) ✅</button>
                            </form>
                        <% } %>
                        <% if (perms.canReject) { %>
                            <form action="/admin/action" method="POST" onsubmit="return confirm('تأكيد رسوب المتدرب وطرد من الأكاديمية؟');" style="display:flex; gap:5px; flex:1;">
                                <input type="hidden" name="userId" value="<%= app.id %>"><input type="hidden" name="action" value="fail_training">
                                <input type="text" name="reason" placeholder="سبب الرسوب..." required style="flex:1; margin:0;"><button type="submit" class="btn-danger">رسوب ورفض ❌</button>
                            </form>
                        <% } %>
                    </div>
                </div>
            <% }) %>
        <% } %>

        <h2 style="color: var(--primary); border-bottom: 2px solid var(--primary); padding-bottom: 10px; margin-top: 50px;">📄 المتقدمين الجدد (<%= newApps.length %> طلب)</h2>
        <% if (newApps.length === 0) { %>
            <p style="color: gray;">لا توجد طلبات تقديم جديدة.</p>
        <% } else { %>
            <% newApps.forEach(app => { %>
                <div class="app-card">
                    <h3 style="color: white; margin-bottom: 10px;">👤 المتقدم: <%= app.personalInfo?.realName || app.username %> <span style="font-size:12px; color:gray;">(<%= app.date %>)</span></h3>
                    
                    <div class="info-grid">
                        <div class="info-item">الهوية: <span><%= app.personalInfo?.nationalId || 'غير متوفر' %></span></div>
                        <div class="info-item">العمر: <span><%= app.personalInfo?.age || 'غير متوفر' %></span></div>
                        <div class="info-item">الجنسية: <span><%= app.personalInfo?.nationality || 'غير متوفر' %></span></div>
                        <div class="info-item">الصورة: <a href="<%= app.personalInfo?.imageUrl || '#' %>" target="_blank" style="color:var(--primary);">عرض الصورة 🖼️</a></div>
                    </div>

                    <div style="background: rgba(0,0,0,0.3); padding: 15px; border-radius: 8px; margin-bottom: 15px;">
                        <h4 style="color: var(--warning); margin-bottom: 10px;">إجابات المقابلة:</h4>
                        <% Object.entries(app.answers || {}).forEach(([key, ans]) => { 
                            const qIndex = parseInt(key.split('_')[1]); const qLabel = questions[qIndex] ? questions[qIndex].label : key;
                        %>
                            <p style="color: gray; font-size: 13px; margin: 0;"><%= qLabel %></p>
                            <p style="color: white; margin-bottom: 10px;"><%= ans %></p>
                        <% }) %>
                    </div>

                    <div style="display:flex; gap:10px;">
                        <% if (perms.canPreAccept) { %>
                            <form action="/admin/action" method="POST">
                                <input type="hidden" name="userId" value="<%= app.id %>"><input type="hidden" name="action" value="accept">
                                <button type="submit" class="btn-success">قبول مبدئي (دخول الأكاديمية) 🎓</button>
                            </form>
                        <% } %>
                        <% if (perms.canReject) { %>
                            <form action="/admin/action" method="POST" style="display:flex; gap:5px; flex:1;">
                                <input type="hidden" name="userId" value="<%= app.id %>"><input type="hidden" name="action" value="reject">
                                <input type="text" name="reason" placeholder="سبب الرفض..." required style="flex:1; margin:0;"><button type="submit" class="btn-danger">رفض الطلب ❌</button>
                            </form>
                        <% } %>
                    </div>
                </div>
            <% }) %>
        <% } %>
    </div>
</body>
</html>