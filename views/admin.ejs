<!DOCTYPE html>
<html lang="ar">
<head>
    <meta charset="UTF-8">
    <title>إدارة التقديمات الجديدة</title>
    <link rel="stylesheet" href="/style.css">
    <style>
        .app-card { background: rgba(0,0,0,0.5); padding: 20px; border-radius: 10px; margin-bottom: 20px; border-right: 5px solid var(--primary); }
        .info-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 10px; margin-bottom: 15px; background: rgba(255,255,255,0.05); padding: 15px; border-radius: 8px; }
        .info-item { color: white; font-size: 14px; }
        .info-item span { color: var(--warning); font-weight: bold; }
    </style>
</head>
<body>
    <%- include('partials/navbar') %>
    <div class="container fade-in">
        <a href="/system" class="btn-secondary" style="margin-bottom: 20px;">⬅️ العودة للوحة المركزية</a>
        <h1 style="text-align:center; color:var(--primary); margin-bottom: 30px;">📄 إدارة التقديمات الجديدة</h1>

        <% 
        let newApps = [];
        Object.entries(db).forEach(([id, app]) => {
            if (app.status === 'applied') newApps.push({ id, ...app });
        });
        %>

        <h2 style="color: white; border-bottom: 2px solid var(--primary); padding-bottom: 10px;">المتقدمين الجدد (<%= newApps.length %> طلب)</h2>
        <% if (newApps.length === 0) { %>
            <p style="color: gray;">لا توجد طلبات تقديم جديدة حالياً.</p>
        <% } else { %>
            <% newApps.forEach(app => { %>
                <div class="app-card">
                    <h3 style="color: white; margin-bottom: 10px;">👤 المتقدم: <%= app.personalInfo?.realName || app.username %> <span style="font-size:12px; color:gray;">(<%= app.date %>)</span></h3>
                    
                    <div class="info-grid">
                        <div class="info-item">الهوية: <span><%= app.personalInfo?.nationalId || 'غير متوفر' %></span></div>
                        <div class="info-item">العمر: <span><%= app.personalInfo?.age || 'غير متوفر' %></span></div>
                        <div class="info-item">الجنسية: <span><%= app.personalInfo?.nationality || 'غير متوفر' %></span></div>
                        <div class="info-item">الديسكورد: <span><%= app.username %></span></div>
                        <div class="info-item">الصورة: <a href="<%= app.personalInfo?.imageUrl || '#' %>" target="_blank" style="color:var(--primary);">عرض الصورة 🖼️</a></div>
                    </div>

                    <div style="background: rgba(0,0,0,0.3); padding: 15px; border-radius: 8px; margin-bottom: 15px;">
                        <h4 style="color: var(--warning); margin-bottom: 10px;">إجابات المقابلة:</h4>
                        <% Object.entries(app.answers || {}).forEach(([key, ans]) => { 
                            const qIndex = parseInt(key.split('_')[1]); const qLabel = questions[qIndex] ? questions[qIndex].label : key;
                        %>
                            <p style="color: gray; font-size: 13px; margin: 0;"><%= qLabel %></p>
                            <p style="color: white; margin-bottom: 10px;"><%= ans %></p>
                        <% }) %>
                    </div>

                    <div style="display:flex; gap:10px;">
                        <% if (perms.canPreAccept) { %>
                            <form action="/admin/action" method="POST">
                                <input type="hidden" name="userId" value="<%= app.id %>"><input type="hidden" name="action" value="accept">
                                <button type="submit" class="btn-success">قبول مبدئي (دخول الأكاديمية) 🎓</button>
                            </form>
                        <% } %>
                        <% if (perms.canReject) { %>
                            <form action="/admin/action" method="POST" style="display:flex; gap:5px; flex:1;">
                                <input type="hidden" name="userId" value="<%= app.id %>"><input type="hidden" name="action" value="reject">
                                <input type="text" name="reason" placeholder="سبب الرفض..." required style="flex:1; margin:0;"><button type="submit" class="btn-danger">رفض الطلب ❌</button>
                            </form>
                        <% } %>
                    </div>
                </div>
            <% }) %>
        <% } %>
    </div>
</body>
</html>