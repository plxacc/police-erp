<!DOCTYPE html>
<html lang="ar">
<head>
    <meta charset="UTF-8">
    <title>إدارة الشهادات العسكرية</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <%- include('partials/navbar') %>
    
    <div class="container fade-in">
        <a href="/system" class="btn-secondary" style="margin-bottom: 20px;">⬅️ العودة للوحة المركزية</a>
        <h1 style="text-align:center; color:var(--primary); margin-bottom: 30px;">📜 إدارة الشهادات والرخص</h1>

        <% 
        const allCerts = Object.entries(certTypes);
        allCerts.forEach(([certId, cert]) => { 
            const certSettings = certsDB.settings[certId] || { open: false, questions: [] };
            
            let pendingApps = [];
            for (let userId in certsDB.apps) {
                if (certsDB.apps[userId][certId] && certsDB.apps[userId][certId].status === 'pending') {
                    pendingApps.push({ userId, ...certsDB.apps[userId][certId] });
                }
            }
            const isOpen = certSettings.open;
            const targetGroup = cert.type === 'enlisted' ? 'أفراد' : 'ضباط صف';
        %>
            
            <div class="collapsible-header" onclick="toggleSection('cert_<%= certId %>')">
                <% if (isOpen) { %>
                    <h2 style="color: var(--success); margin:0;">
                        <%= cert.name %> (شريحة: <%= targetGroup %>) [<%= pendingApps.length %> طلبات]
                    </h2>
                <% } else { %>
                    <h2 style="color: var(--text-muted); margin:0;">
                        <%= cert.name %> (شريحة: <%= targetGroup %>) [<%= pendingApps.length %> طلبات]
                    </h2>
                <% } %>
                <span style="color: white;">▼ طي / فتح</span>
            </div>
            
            <div id="cert_<%= certId %>" class="collapsible-content card" style="border-color: var(--primary); margin-bottom: 30px; display: none;">
                
                <div style="display:flex; justify-content:space-between; align-items:center; border-bottom:1px solid gray; padding-bottom:15px; margin-bottom:15px;">
                    <p style="color:white; font-size:18px;">الحالة: 
                        <% if (isOpen) { %>
                            <strong style="color: var(--success);">مفتوح للتقديم</strong>
                        <% } else { %>
                            <strong style="color: var(--text-muted);">مغلق</strong>
                        <% } %>
                    </p>
                    
                    <form action="/system/certificates/toggle" method="POST">
                        <input type="hidden" name="certId" value="<%= certId %>">
                        <% if (isOpen) { %>
                            <button class="btn-danger">إغلاق التقديم</button>
                        <% } else { %>
                            <button class="btn-success">فتح التقديم</button>
                        <% } %>
                    </form>
                </div>

                <h3 style="color:var(--warning);">📝 أسئلة اختبار الشهادة</h3>
                <form action="/system/certificates/questions/add" method="POST" style="display:flex; gap:10px; margin-bottom:15px;">
                    <input type="hidden" name="certId" value="<%= certId %>">
                    <input type="text" name="questionLabel" required placeholder="اكتب السؤال الجديد..." style="margin:0;">
                    <button class="btn-success">إضافة سؤال</button>
                </form>
                
                <table style="background: rgba(0,0,0,0.3); margin-bottom: 20px;">
                    <% 
                    const questions = certSettings.questions || [];
                    questions.forEach((q, index) => { 
                    %>
                        <tr>
                            <td style="color: white; width: 80%;"><%= index + 1 %>. <%= q.label %></td>
                            <td style="text-align:left;">
                                <form action="/system/certificates/questions/delete" method="POST">
                                    <input type="hidden" name="certId" value="<%= certId %>">
                                    <input type="hidden" name="index" value="<%= index %>">
                                    <button class="btn-danger" style="padding: 5px 15px;">حذف</button>
                                </form>
                            </td>
                        </tr>
                    <% }) %>
                </table>

                <h3 style="color:var(--primary);">⏳ الطلبات قيد المراجعة (<%= pendingApps.length %>)</h3>
                <% if(pendingApps.length === 0) { %>
                    <p style="color:gray;">لا توجد طلبات معلقة حالياً.</p>
                <% } else { %>
                    <div class="scrollable-box" style="max-height: 400px;">
                        <% pendingApps.forEach(app => { %>
                            <div style="background:rgba(0,0,0,0.4); padding:15px; border-radius:10px; margin-bottom:10px; border-right:4px solid var(--warning);">
                                <h4 style="color:white; margin-bottom:10px;">
                                    <%= app.username %> <span style="font-size:12px; color:gray;">(<%= app.date %>)</span>
                                </h4>
                                
                                <div style="background:rgba(255,255,255,0.05); padding:10px; border-radius:5px; margin-bottom:15px;">
                                    <% 
                                    const appAnswers = app.answers || {};
                                    Object.entries(appAnswers).forEach(([key, ans]) => { 
                                        const qIndex = parseInt(key.split('_')[1]);
                                        const qLabel = questions[qIndex] ? questions[qIndex].label : key;
                                    %>
                                        <p style="color:var(--warning); font-size:13px; margin:0;"><%= qLabel %></p>
                                        <p style="color:white; margin-bottom:10px;"><%= ans %></p>
                                    <% }) %>
                                </div>

                                <div style="display:flex; gap:10px;">
                                    <form action="/system/certificates/action" method="POST">
                                        <input type="hidden" name="userId" value="<%= app.userId %>">
                                        <input type="hidden" name="certId" value="<%= certId %>">
                                        <input type="hidden" name="action" value="accept">
                                        <button class="btn-success" style="padding:5px 15px;">منح الشهادة (نجاح)</button>
                                    </form>
                                    <form action="/system/certificates/action" method="POST">
                                        <input type="hidden" name="userId" value="<%= app.userId %>">
                                        <input type="hidden" name="certId" value="<%= certId %>">
                                        <input type="hidden" name="action" value="reject">
                                        <button class="btn-danger" style="padding:5px 15px;">رفض (رسوب)</button>
                                    </form>
                                </div>
                            </div>
                        <% }) %>
                    </div>
                <% } %>
            </div>
        <% }) %>

    </div>
    
    <script>
        function toggleSection(id) { 
            const el = document.getElementById(id); 
            if (el) el.style.display = el.style.display === 'none' ? 'block' : 'none'; 
        }
    </script>
</body>
</html>