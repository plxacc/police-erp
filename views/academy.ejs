<!DOCTYPE html>
<html lang="ar">
<head>
    <meta charset="UTF-8"><title>الأكاديمية العسكرية</title><link rel="stylesheet" href="/style.css">
    <style>
        .app-card { background: rgba(0,0,0,0.5); padding: 20px; border-radius: 10px; margin-bottom: 20px; border-right: 5px solid #9B59B6; }
        .info-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 10px; margin-bottom: 15px; background: rgba(255,255,255,0.05); padding: 15px; border-radius: 8px; }
        .info-item { color: white; font-size: 14px; } .info-item span { color: var(--warning); font-weight: bold; }
        .grade-input { width: 60px; padding: 5px; background: #222; border: 1px solid var(--warning); color: white; text-align: center; border-radius: 5px; }
        .grade-input[readonly] { border-color: #555; color: #aaa; background: #111; cursor: not-allowed; }
        .answers-box { display: none; background: rgba(0,0,0,0.3); padding: 15px; border-radius: 8px; margin-bottom: 15px; margin-top: 10px; border-right: 3px solid #9B59B6; animation: fadeIn 0.3s; }
        .grader-name { font-size: 11px; color: #3498DB; display: block; margin-top: 5px; font-weight:bold; background: rgba(0,0,0,0.5); padding: 2px; border-radius: 3px; }
        details summary { cursor: pointer; font-size: 18px; font-weight: bold; padding: 15px; background: rgba(255,255,255,0.05); border-radius: 8px; list-style: none; outline: none; }
        details[open] summary { margin-bottom: 20px; background: rgba(255,255,255,0.1); }
    </style>
</head>
<body>
    <%- include('partials/navbar') %>
    <div class="container fade-in">
        <a href="/system" class="btn-secondary" style="margin-bottom: 20px;">⬅️ العودة للوحة المركزية</a>
        <h1 style="text-align:center; color:#9B59B6; margin-bottom: 30px;">🎓 أكاديمية الشرطة</h1>
        <input type="text" id="searchAcademy" class="search-bar" placeholder="🔍 ابحث بالاسم، الديسكورد، أو الرقم الوطني..." onkeyup="filterCards('searchAcademy', 'academyContainer')">

        <% let academyApps = []; let failedApps = []; Object.entries(db).forEach(([id, app]) => { if (app.status === 'academy') academyApps.push({ id, ...app }); else if (app.status === 'failed_academy') failedApps.push({ id, ...app }); }); %>

        <div id="academyContainer">
            <details open style="margin-bottom: 30px;">
                <summary style="color: #9B59B6; border-bottom: 2px solid #9B59B6;">⏳ المتدربين الحاليين (<%= academyApps.length %>) <span>▼</span></summary>
                <% if (academyApps.length === 0) { %><p style="color: gray; margin-bottom: 40px;">لا يوجد متدربين حالياً.</p><% } %>
                <div style="max-height: 65vh; overflow-y: auto; padding-right: 15px; border-right: 1px solid rgba(255,255,255,0.1);"></div>
                <% academyApps.forEach(app => { %>
                    <div class="searchable-card app-card">
                        <div style="display:flex; justify-content:space-between; margin-bottom:15px;">
                            <h3 style="color: white; margin: 0;">👤 المتدرب: <%= app.personalInfo?.realName || app.username %></h3>
                            <% if (app.grades && app.grades.total > 0) { %>
                                <% if (app.grades.total >= 65) { %> <span style="background: rgba(46, 204, 113, 0.2); border: 1px solid var(--success); padding: 5px 15px; border-radius: 5px; color: var(--success); font-weight:bold;">الدرجة: <%= app.grades.total %>/75 (اجتاز ✅)</span>
                                <% } else { %> <span style="background: rgba(231, 76, 60, 0.2); border: 1px solid var(--danger); padding: 5px 15px; border-radius: 5px; color: var(--danger); font-weight:bold;">الدرجة: <%= app.grades.total %>/75 (لم يجتز ❌)</span> <% } %>
                            <% } else { %> <span style="background: rgba(241, 196, 15, 0.2); border: 1px solid var(--warning); padding: 5px 15px; border-radius: 5px; color: var(--warning); font-weight:bold;">قيد التقييم ⏳</span> <% } %>
                        </div>

                        <div class="info-grid">
                            <div class="info-item">الهوية: <span><%= app.personalInfo?.nationalId || 'غير متوفر' %></span></div>
                            <div class="info-item">العمر: <span><%= app.personalInfo?.age || 'غير متوفر' %></span> | الميلاد: <span><%= app.personalInfo?.dob || '-' %></span></div>
                            <div class="info-item">الجنسية: <span><%= app.personalInfo?.nationality || 'غير متوفر' %></span></div>
                            <div class="info-item">الجوال: <span><%= app.personalInfo?.phone || 'غير متوفر' %></span></div>
                            <div class="info-item">ديسكورد: <span style="user-select: all;"><%= app.username %> ( <%= app.id %> )</span></div>
                            <div class="info-item">الصورة: <a href="<%= app.personalInfo?.imageUrl || '#' %>" target="_blank" style="color:#9B59B6;">عرض الصورة 🖼️</a></div>
                        </div>

                        <button class="btn-secondary" onclick="toggleElement('answers_<%= app.id %>')" style="margin-bottom: 15px;">👁️ عرض إجابات التقديم المبدئي</button>
                        <div id="answers_<%= app.id %>" class="answers-box">
                            <% Object.entries(app.answers || {}).forEach(([key, ans]) => { const qIndex = parseInt(key.split('_')[1]); const qLabel = questions[qIndex] ? questions[qIndex].label : key; %>
                                <p style="color: gray; font-size: 13px; margin: 0;"><%= qLabel %></p><p style="color: white; margin-bottom: 10px; white-space: pre-wrap;"><%= ans %></p>
                            <% }) %>
                        </div>

                        <% if (perms.canGrade || user.perms.isOfficer) { %>
                            <% let g = app.grades || {}; let isOff = user.perms.isOfficer; %>
                            <form action="/admin/grade" method="POST" style="background: rgba(241, 196, 15, 0.1); padding: 15px; border-radius: 8px; margin-bottom: 15px; border: 1px dashed var(--warning);">
                                <h4 style="color: var(--warning); margin-bottom: 10px;">📝 رصد وتقييم المدربين</h4>
                                <input type="hidden" name="userId" value="<%= app.id %>">
                                    <div style="display: flex; gap: 15px; flex-wrap: wrap; align-items: flex-start;">
                                        <div><label style="color:white; font-size:12px;">الاستيقافات (20)</label><br><input type="number" name="stops" max="20" min="0" class="grade-input" style="direction: ltr; font-family: monospace;" value="<%= g.stops?.value || '' %>" <%= g.stops?.value && !isOff ? 'readonly' : '' %>><br>
                                            <% if(g.stops?.grader){ %><%- isOff && g.stops.graderId ? `<a href="/system/personnel?open=${g.stops.graderId}" class="grader-name" style="text-decoration:underline;" title="فتح ملف المقيم مباشرة">` : `<span class="grader-name">` %><%= g.stops.grader %><%- isOff && g.stops.graderId ? `</a>` : `</span>` %><% } %></div>
                                
                                        <div><label style="color:white; font-size:12px;">العمليات (20)</label><br><input type="number" name="ops" max="20" min="0" class="grade-input" style="direction: ltr; font-family: monospace;" value="<%= g.ops?.value || '' %>" <%= g.ops?.value && !isOff ? 'readonly' : '' %>><br>
                                            <% if(g.ops?.grader){ %><%- isOff && g.ops.graderId ? `<a href="/system/personnel?open=${g.ops.graderId}" class="grader-name" style="text-decoration:underline;">` : `<span class="grader-name">` %><%= g.ops.grader %><%- isOff && g.ops.graderId ? `</a>` : `</span>` %><% } %></div>
                                
                                        <div><label style="color:white; font-size:12px;">التفاوض (20)</label><br><input type="number" name="neg" max="20" min="0" class="grade-input" style="direction: ltr; font-family: monospace;" value="<%= g.neg?.value || '' %>" <%= g.neg?.value && !isOff ? 'readonly' : '' %>><br>
                                            <% if(g.neg?.grader){ %><%- isOff && g.neg.graderId ? `<a href="/system/personnel?open=${g.neg.graderId}" class="grader-name" style="text-decoration:underline;">` : `<span class="grader-name">` %><%= g.neg.grader %><%- isOff && g.neg.graderId ? `</a>` : `</span>` %><% } %></div>
                                
                                        <div><label style="color:white; font-size:12px;">اسئله عامة (10)</label><br><input type="number" name="general" max="10" min="0" class="grade-input" style="direction: ltr; font-family: monospace;" value="<%= g.general?.value || '' %>" <%= g.general?.value && !isOff ? 'readonly' : '' %>><br>
                                            <% if(g.general?.grader){ %><%- isOff && g.general.graderId ? `<a href="/system/personnel?open=${g.general.graderId}" class="grader-name" style="text-decoration:underline;">` : `<span class="grader-name">` %><%= g.general.grader %><%- isOff && g.general.graderId ? `</a>` : `</span>` %><% } %></div>
                                
                                        <div><label style="color:white; font-size:12px;">الحضور (5)</label><br><input type="number" name="att" max="5" min="0" class="grade-input" style="direction: ltr; font-family: monospace;" value="<%= g.att?.value || '' %>" <%= g.att?.value && !isOff ? 'readonly' : '' %>><br>
                                            <% if(g.att?.grader){ %><%- isOff && g.att.graderId ? `<a href="/system/personnel?open=${g.att.graderId}" class="grader-name" style="text-decoration:underline;">` : `<span class="grader-name">` %><%= g.att.grader %><%- isOff && g.att.graderId ? `</a>` : `</span>` %><% } %></div>
                                
                                    <div style="margin-top: 18px;"><button type="submit" class="btn-warning" style="color:rgb(255, 255, 255); font-weight:bold; padding: 6px 15px;">حفظ واعتماد 💾</button></div>
                               </div>
                            </form>
                        <% } %>

                        <% if (user.perms.isOfficer) { %>
                        <div style="display:flex; gap:10px; background: rgba(0,0,0,0.3); padding: 15px; border-radius: 8px;">
                            <% if (perms.canFinalAccept) { %>
                                <form action="/admin/enlist" method="POST" onsubmit="return confirm('تأكيد تجنيد الفرد؟');" style="display:flex; gap:10px; flex:2;">
                                    <input type="hidden" name="userId" value="<%= app.id %>"><input type="text" name="militaryCode" required placeholder="الكود العسكري (مثال: 1050)" style="padding: 10px; border-radius: 5px; border: 1px solid var(--success); background: #111; color: white;">
                                    <button type="submit" class="btn-success">تجنيد نهائي واعتماد الكود ✅</button>
                                </form>
                            <% } %>
                            <% if (perms.canReject) { %>
                                <form action="/admin/action" method="POST" style="display:flex; gap:5px; flex:1;">
                                    <input type="hidden" name="userId" value="<%= app.id %>"><input type="hidden" name="action" value="fail_training">
                                    <input type="text" name="reason" placeholder="سبب الرسوب..." required style="flex:1; margin:0;"><button type="submit" class="btn-danger">رسوب ورفض ❌</button>
                                </form>
                            <% } %>
                        </div>
                        <% } %>
                    </div>
                <% }) %>
                </div>
            </details>

            <details style="margin-bottom: 30px;">
                <summary style="color: #e74c3c; border-bottom: 2px solid #e74c3c;">❌ الراسبين بالأكاديمية (الرفض النهائي) (<%= failedApps.length %>) <span>▼</span></summary>
                <% if (failedApps.length === 0) { %><p style="color: gray;">لا يوجد راسبين.</p><% } %>
                <div style="max-height: 65vh; overflow-y: auto; padding-right: 15px; border-right: 1px solid rgba(255,255,255,0.1);"></div>
                <% failedApps.forEach(app => { %>
                    <div class="searchable-card app-card" style="border-color: #e74c3c; opacity: 0.8;">
                        <div style="display:flex; justify-content:space-between; margin-bottom:15px;">
                            <h3 style="color: #e74c3c; margin: 0;">❌ الراسب: <%= app.personalInfo?.realName || app.username %> <br><span style="font-size:14px; color:white;">(السبب: <%= app.rejectReason || 'غير مسجل' %>)</span></h3>
                            <span style="background: rgba(231, 76, 60, 0.2); border: 1px solid var(--danger); padding: 5px 15px; border-radius: 5px; color: var(--danger); font-weight:bold; align-self:flex-start;">الدرجة النهائية: <%= app.grades?.total || '0' %>/75</span>
                        </div>

                        <% if (app.grades) { %>
                        <div style="display:flex; gap:10px; background: rgba(0,0,0,0.3); padding: 10px; border-radius: 8px; margin-bottom: 15px; flex-wrap:wrap;">
                            <div class="info-item">الاستيقافات: <span style="font-family: monospace; font-size: 15px;"><%= app.grades.stops?.value||'0' %></span> <br><small style="color:gray;"><%= app.grades.stops?.grader||'-' %></small></div>
                            <div class="info-item">العمليات: <span style="font-family: monospace; font-size: 15px;"><%= app.grades.ops?.value||'0' %></span> <br><small style="color:gray;"><%= app.grades.ops?.grader||'-' %></small></div>
                            <div class="info-item">التفاوض: <span style="font-family: monospace; font-size: 15px;"><%= app.grades.neg?.value||'0' %></span> <br><small style="color:gray;"><%= app.grades.neg?.grader||'-' %></small></div>
                            <div class="info-item">الأسئلة العامة: <span style="font-family: monospace; font-size: 15px;"><%= app.grades.general?.value||'0' %></span> <br><small style="color:gray;"><%= app.grades.general?.grader||'-' %></small></div>
                            <div class="info-item">الحضور: <span style="font-family: monospace; font-size: 15px;"><%= app.grades.att?.value||'0' %></span> <br><small style="color:gray;"><%= app.grades.att?.grader||'-' %></small></div>
                        </div>
                        <% } %}

                        <div class="info-grid">
                            <div class="info-item">الهوية: <span><%= app.personalInfo?.nationalId || 'غير متوفر' %></span></div>
                            <div class="info-item">العمر: <span><%= app.personalInfo?.age || 'غير متوفر' %></span> | الميلاد: <span><%= app.personalInfo?.dob || '-' %></span></div>
                            <div class="info-item">الجنسية: <span><%= app.personalInfo?.nationality || 'غير متوفر' %></span></div>
                            <div class="info-item">الجوال: <span><%= app.personalInfo?.phone || 'غير متوفر' %></span></div>
                            <div class="info-item">ديسكورد: <span style="user-select: all;"><%= app.username %> ( <%= app.id %> )</span></div>
                            <div class="info-item">الصورة: <a href="<%= app.personalInfo?.imageUrl || '#' %>" target="_blank" style="color:var(--primary);">عرض الصورة 🖼️</a></div>
                        </div>

                        <button class="btn-secondary" onclick="toggleElement('answers_<%= app.id %>')" style="margin-bottom: 15px; font-size:12px;">👁️ عرض الإجابات (للأرشفة)</button>
                        <div id="answers_<%= app.id %>" class="answers-box">
                            <% Object.entries(app.answers || {}).forEach(([key, ans]) => { const qIndex = parseInt(key.split('_')[1]); const qLabel = questions[qIndex] ? questions[qIndex].label : key; %>
                                <p style="color: gray; font-size: 13px; margin: 0;"><%= qLabel %></p><p style="color: white; margin-bottom: 10px;"><%= ans %></p>
                            <% }) %>
                        </div>

                        <% if (user.perms.isOfficer && perms.canFinalAccept) { %>
                            <form action="/admin/enlist" method="POST" onsubmit="return confirm('إرجاع وتجنيد الراسب كفرصة ثانية؟');" style="display:flex; gap:10px; background:rgba(46, 204, 113, 0.1); padding:10px; border-radius:8px;">
                                <input type="hidden" name="userId" value="<%= app.id %>">
                                <input type="text" name="militaryCode" required placeholder="الكود العسكري (تجنيد استثنائي)" style="padding: 10px; border-radius: 5px; border: 1px solid var(--success); background: #111; color: white;">
                                <button type="submit" class="btn-success">تجنيد نهائي واعتماد الكود ♻️</button>
                            </form>
                        <% } %>
                    </div>
                </div>
            </details>
        </div>
    </div>
    <script>
        function toggleElement(id) { const el = document.getElementById(id); el.style.display = el.style.display === 'block' ? 'none' : 'block'; }
        function filterCards(inputId, containerId) { const filter = document.getElementById(inputId).value.toLowerCase(); const cards = document.getElementById(containerId).getElementsByClassName('searchable-card'); for (let i = 0; i < cards.length; i++) { let text = cards[i].innerText.toLowerCase(); cards[i].style.display = text.includes(filter) ? "" : "none"; } }
    </script>
</body>
</html>