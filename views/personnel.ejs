<!DOCTYPE html>
<html lang="ar">
<head>
    <meta charset="UTF-8">
    <title>إدارة العسكر والعهدة</title>
    <link rel="stylesheet" href="/style.css">
    <style>
        .modal { display: none; position: fixed; z-index: 10000; left: 0; top: 0; width: 100%; height: 100%; background-color: rgba(0, 0, 0, 0.85) !important; backdrop-filter: blur(8px) !important; }
        .modal-content { 
            background: linear-gradient(145deg, #111827, #020617) !important;
            border: 1px solid rgba(255,255,255,0.1); border-top: 4px solid var(--primary); border-radius: 16px; 
            box-shadow: 0 30px 60px rgba(0, 0, 0, 0.9) !important;
            padding: 25px; margin: 4% auto; width: 95%; max-width: 850px; max-height: 85vh; overflow-y: auto; color: white; position: relative; 
            animation: slideDownModal 0.4s cubic-bezier(0.16, 1, 0.3, 1);
        }
        @keyframes slideDownModal { from { transform: translateY(-40px) scale(0.98); opacity: 0; } to { transform: translateY(0) scale(1); opacity: 1; } }
        
        .profile-section { background: rgba(15, 20, 30, 0.6) !important; padding: 20px; border-radius: 12px; margin-bottom: 25px; border: 1px solid #27272a; border-right-width: 4px; transition: 0.3s; }
        .section-purple { background: rgba(155, 89, 182, 0.05) !important; border-right-color: #9B59B6; }
        .section-red { background: rgba(231, 76, 60, 0.05) !important; border-right-color: #e74c3c; }
        .section-blue { background: rgba(52, 152, 219, 0.05) !important; border-right-color: #3498DB; }
        .profile-section h3 { margin-bottom: 20px; font-size: 18px; border-bottom: 1px solid #333; padding-bottom: 10px; font-weight: bold; }
        
        .form-grid { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 12px; }
        .form-grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
        .form-control { width: 100%; padding: 10px 14px; font-size: 13px; background: rgba(0,0,0,0.5); border: 1px solid #3f3f46; color: white; border-radius: 6px; box-sizing: border-box; transition: 0.3s; }
        .form-control:focus { border-color: var(--primary); outline: none; background: rgba(0,0,0,0.8); }
        .btn-compact { padding: 8px 15px; font-size: 13px; border-radius: 6px; font-weight: bold; cursor: pointer; border: none; }
        .btn-block { width: 100%; display: block; margin-top: 10px; padding: 10px; font-size: 13px; font-weight: bold; border-radius: 8px; cursor: pointer; border: none; }
        
        .cert-tag { background: #23182b; border: 1px solid #9B59B6; padding: 6px 12px; border-radius: 8px; display: flex; align-items: center; gap: 10px; font-size: 12px; }
        .badge-group { display: flex; gap: 8px; flex-wrap: wrap; justify-content: center; margin-top: 12px; }
        .badge-custom { padding: 6px 14px; border-radius: 20px; font-size: 12px; font-weight: bold; background: #27272a; border: 1px solid #3f3f46; color: #d4d4d8; }
        .inner-box { background: rgba(0,0,0,0.25); padding: 15px; border-radius: 8px; border: 1px solid #27272a; }
        .inner-label { color:#a1a1aa; font-size:12px; display:block; margin-bottom:8px; font-weight: bold; }
        
        .drag-scroll { overflow-y: auto; overflow-x: hidden; cursor: grab; max-height: 600px; border-radius: 8px; border: 1px solid #27272a; user-select: none; background: #18181b; }
        .drag-scroll:active { cursor: grabbing; }
        .drag-scroll::-webkit-scrollbar { width: 8px; }
        .drag-scroll::-webkit-scrollbar-track { background: rgba(0,0,0,0.2); }
        .drag-scroll::-webkit-scrollbar-thumb { background: rgba(14, 165, 233, 0.5); border-radius: 4px; }
        .drag-scroll::-webkit-scrollbar-thumb:hover { background: var(--primary); }

        .close-btn { color: var(--text-muted); position: absolute; top: 20px; left: 25px; font-size: 30px; font-weight: bold; cursor: pointer; transition: 0.3s; background: rgba(0,0,0,0.3); border-radius: 50%; width: 40px; height: 40px; display: flex; justify-content: center; align-items: center; }
        .close-btn:hover { color: white; background: var(--danger); transform: rotate(90deg); box-shadow: 0 0 15px var(--danger-glow); }
    </style>
</head>
<body>
    <%- include('partials/navbar') %>
    <div class="container fade-in">
        <a href="/system" class="btn-secondary btn-compact" style="margin-bottom: 20px; display: inline-block;">⬅️ العودة للوحة المركزية</a>
        
        <div class="card" style="border-color: var(--danger); background: linear-gradient(145deg, rgba(15, 20, 30, 0.8), rgba(5, 8, 15, 0.9));">
            <h2 style="color: var(--danger); margin-bottom: 20px;">🎖️ سجل الأفراد والضباط</h2>
            <input type="text" id="searchPersonnel" class="search-bar form-control" style="font-size: 14px; padding: 12px; margin-bottom: 20px;" placeholder="🔍 ابحث بالاسم، الآيدي، أو الرقم الوطني..." onkeyup="filterTable('searchPersonnel', 'personnelTable')">
            
            <div class="drag-scroll" id="mainDragArea">
                <table id="personnelTable" style="margin: 0; width: 100%; border-collapse: collapse;">
                    <tr class="header-row" style="background: rgba(14, 165, 233, 0.15);">
                        <th style="padding: 15px; text-align:right;">العسكري</th> 
                        <th style="padding: 15px; text-align:right;">الرتبة</th> 
                        <th style="text-align:center; padding: 15px;">الإجراءات</th>
                    </tr>
                    <% list.forEach(member => { %>
                        <tr class="searchable-row" style="border-bottom: 1px solid #27272a;">
                            <td style="font-weight:bold; color:#e4e4e7; padding: 15px;">
                                <%= member.realName %> <br>
                                <span style="font-size:11px; color:#a1a1aa;">ديسكورد: <%= member.username %> | آيدي: <%= member.id %></span><br>
                                <span style="font-size:12px; color:var(--primary);">الرقم الوطني: <%= member.nationalId %></span>
                            </td>
                            <td style="color:var(--warning); font-weight:bold; padding: 15px;">
                                <%= member.siteRank %> <br>
                                <span style="color:#a1a1aa; font-weight:normal; font-size:11px;">شريحة: <%= member.discordRank %></span>
                            </td>
                            <td style="text-align:center; padding: 15px;">
                                <button type="button" class="btn-primary btn-compact" onclick="openModal('modal_profile_<%= member.id %>')">فتح الملف 📂</button>
                            </td>
                        </tr>
                    <% }) %>
                </table>
            </div>
        </div>
    </div>

    <% 
        let weaponsMap = {}; let vehiclesMap = {};
        (custody.weaponLogs || []).forEach((l, i) => { if(!weaponsMap[l.receiverDiscordId]) weaponsMap[l.receiverDiscordId] = []; weaponsMap[l.receiverDiscordId].push({...l, originalIndex: i}); });
        (custody.vehicleLogs || []).forEach((l, i) => { if(!vehiclesMap[l.receiverDiscordId]) vehiclesMap[l.receiverDiscordId] = []; vehiclesMap[l.receiverDiscordId].push({...l, originalIndex: i}); });
    %>

    <% list.forEach(member => { 
        const memberWeapons = weaponsMap[member.id] || [];
        const memberVehicles = vehiclesMap[member.id] || [];
    %>
        <div id="modal_profile_<%= member.id %>" class="modal">
            <div class="modal-content">
                <span class="close-btn" onclick="closeModal('modal_profile_<%= member.id %>')">&times;</span>
                
                <div style="text-align:center; padding-bottom: 20px; margin-bottom:25px; border-bottom: 1px solid #27272a;">
                    <h2 style="color:#f4f4f5; margin-bottom:10px; font-size: 22px;">🗂️ ملف العسكري: <span style="color:var(--warning);"><%= member.realName %></span></h2>
                    <div class="badge-group">
                        <span class="badge-custom" style="color:#4ade80; border-color:#14532d; background: rgba(74,222,128,0.1);">📅 انضمام: <%= member.joinDate || 'قديم' %></span>
                        <span class="badge-custom" style="color:#c084fc; border-color:#581c87; background: rgba(192,132,252,0.1);">🕒 آخر دخول: <%= member.lastLogin || 'غير معروف' %></span>
                    </div>
                </div>
                
                <div class="profile-section section-purple">
                    <h3 style="color: #c084fc;">🎖️ الشهادات والرخص الحاصل عليها</h3>
                    <% if(!member.certs || member.certs.length === 0) { %>
                        <p style="color:#71717a; font-size:13px; margin-bottom: 15px;">لا توجد شهادات مسجلة لهذا العسكري.</p>
                    <% } else { %>
                        <div style="display:flex; gap:10px; flex-wrap:wrap; margin-bottom: 20px;">
                            <% member.certs.forEach(cId => { %>
                                <div class="cert-tag">
                                    <span style="color: #e4e4e7;"><%= certTypes[cId] ? certTypes[cId].name : cId %></span>
                                    <form action="/system/personnel/revoke-cert" method="POST" onsubmit="return confirm('سحب الشهادة؟');" style="margin:0;"><input type="hidden" name="targetId" value="<%= member.id %>"><input type="hidden" name="certId" value="<%= cId %>"><button class="btn-danger" style="padding: 4px 8px; font-size: 11px; border-radius:4px; border:none;">سحب ❌</button></form>
                                </div>
                            <% }) %>
                        </div>
                    <% } %>
                    
                    <div class="inner-box" style="display: flex; align-items: flex-end; gap: 10px;">
                        <div style="flex:1;">
                            <span class="inner-label">منح شهادة استثنائية (مباشرة)</span>
                            <form action="/system/personnel/grant-cert-direct" method="POST" style="display:flex; gap:10px; margin:0;">
                                <input type="hidden" name="targetId" value="<%= member.id %>">
                                <select name="certId" required class="form-control" style="flex:1;"><option value="" disabled selected>-- اختر شهادة لمنحها مباشرة --</option><% Object.entries(certTypes).forEach(([cId, cInfo]) => { %> <option value="<%= cId %>"><%= cInfo.name %></option> <% }) %></select>
                                <button type="submit" class="btn-success btn-compact" onclick="return confirm('تأكيد منح الشهادة مباشرة؟');" style="border:none; padding: 0 20px;">منح 📜</button>
                            </form>
                        </div>
                    </div>
                </div>

                <div class="profile-section section-red">
                    <h3 style="color: #f87171;">⚙️ الإجراءات الإدارية والترقيات</h3>
                    
                    <div class="form-grid-2">
                        <div class="inner-box">
                            <span class="inner-label">شريحة الديسكورد</span>
                            <form action="/system/personnel/action" method="POST" style="display:flex; gap:8px;">
                                <input type="hidden" name="targetId" value="<%= member.id %>"><input type="hidden" name="action" value="update_discord">
                                <select name="newDiscordRole" class="form-control"><option value="enlisted" <%= member.discordRank === 'أفراد' ? 'selected' : '' %>>أفراد</option><option value="nco" <%= member.discordRank === 'ضباط صف' ? 'selected' : '' %>>ضباط صف</option><option value="officer" <%= member.discordRank === 'ضباط' ? 'selected' : '' %>>ضباط</option></select>
                                <button class="btn-primary btn-compact" style="border:none;">حفظ</button>
                            </form>
                        </div>
                    </div>

                    <div class="inner-box" style="margin-top: 15px; margin-bottom: 15px;">
                        <span class="inner-label">تحديث بيانات النظام والرتبة العسكرية</span>
                        <form action="/system/personnel/action" method="POST">
                            <input type="hidden" name="targetId" value="<%= member.id %>"><input type="hidden" name="action" value="update_site">
                            <div class="form-grid" style="margin-bottom: 10px;">
                                <input type="text" name="newRealName" value="<%= member.realName %>" placeholder="الاسم الثنائي" required class="form-control" style="margin:0;">
                                <input type="text" name="newNationalId" value="<%= member.nationalId %>" placeholder="الرقم الوطني" required class="form-control" style="margin:0;">
                                <select name="newSiteRank" class="form-control" style="margin:0;"><% RANKS_LADDER.forEach(rank => { %><option value="<%= rank %>" <%= member.siteRank === rank ? 'selected' : '' %>><%= rank %></option><% }) %></select>
                            </div>
                            <button class="btn-warning btn-block" style="color:black;">حفظ بيانات النظام 💾</button>
                        </form>
                    </div>

                    <form id="fireForm_<%= member.id %>" action="/system/personnel/action" method="POST">
                        <input type="hidden" name="targetId" value="<%= member.id %>"><input type="hidden" name="action" value="fire"><input type="hidden" name="reason" id="fireReason_<%= member.id %>">
                        <button type="button" class="btn-danger btn-block" onclick="firePersonnel('<%= member.id %>')">فصل وطي قيد من القطاع ❌</button>
                    </form>
                </div>

                <div class="profile-section section-blue" style="margin-bottom: 0;">
                    <h3 style="color: #60a5fa;">📦 صرف واسترجاع العهدة</h3>
                    <div class="form-grid-2">
                        <div class="inner-box">
                            <h4 style="color:#60a5fa; margin-bottom:15px; font-size:14px; text-align:center;">🔫 صرف سلاح</h4>
                            <form action="/custody/weapons/issue" method="POST">
                                <input type="hidden" name="discordId" value="<%= member.id %>"><input type="hidden" name="receiverName" value="<%= member.realName %>"><input type="hidden" name="nationalId" value="<%= member.nationalId %>">
                                <select name="weaponType" required class="form-control" style="margin-bottom:10px;"><option value="" disabled selected>-- اختر السلاح --</option><% (custody.weaponTypes || []).forEach(type => { %> <option value="<%= type %>"><%= type %></option> <% }) %></select>
                                <div style="display:flex; gap:8px;"><input type="text" name="serialNumber" required placeholder="السيريال (S/N)" class="form-control" style="flex:1; font-family: monospace;"><button class="btn-primary btn-compact" style="border:none;">صرف</button></div>
                            </form>
                        </div>
                        <div class="inner-box">
                            <h4 style="color:#facc15; margin-bottom:15px; font-size:14px; text-align:center;">🚓 صرف مركبة</h4>
                            <form action="/custody/vehicles/issue" method="POST">
                                <input type="hidden" name="discordId" value="<%= member.id %>"><input type="hidden" name="receiverName" value="<%= member.realName %>"><input type="hidden" name="nationalId" value="<%= member.nationalId %>">
                                <select name="vehicleType" required class="form-control" style="margin-bottom:10px;"><option value="" disabled selected>-- اختر المركبة --</option><% (custody.vehicleTypes || []).forEach(type => { %> <option value="<%= type %>"><%= type %></option> <% }) %></select>
                                <div style="display:flex; gap:8px;"><input type="text" name="plateNumber" required placeholder="رقم اللوحة" class="form-control" style="flex:1; font-family: monospace;"><button class="btn-warning btn-compact" style="color:black; border:none;">صرف</button></div>
                            </form>
                        </div>
                    </div>

                    <div style="margin-top: 20px;">
                        <span class="inner-label" style="margin-bottom:10px;">📋 العهدة المسجلة حالياً:</span>
                        <% if(memberWeapons.length === 0 && memberVehicles.length === 0) { %><p style="color:#71717a; font-size:13px; text-align:center; padding: 12px; background: rgba(0,0,0,0.3); border-radius: 8px;">لا توجد عهدة مسجلة.</p><% } else { %>
                            <table style="background: rgba(0,0,0,0.3); width:100%; border-radius:8px; border: 1px solid #27272a; border-collapse: collapse;">
                                <% memberWeapons.forEach(w => { %><tr style="border-bottom: 1px solid #27272a;"><td style="color:#e4e4e7; padding: 12px; font-size:13px;">🔫 <%= w.weaponType %> <br><span style="color:#71717a; font-family: monospace;">S/N: <%= w.serialNumber %></span></td><td style="text-align:left; padding: 12px;"><form action="/system/custody/return" method="POST" onsubmit="return confirm('تأكيد سحب السلاح؟');" style="margin:0;"><input type="hidden" name="type" value="weapon"><input type="hidden" name="index" value="<%= w.originalIndex %>"><button class="btn-secondary btn-compact" style="padding:6px 12px; font-size:11px; border:none;">استرجاع</button></form></td></tr><% }) %>
                                <% memberVehicles.forEach(v => { %><tr style="border-bottom: 1px solid #27272a;"><td style="color:#e4e4e7; padding: 12px; font-size:13px;">🚓 <%= v.vehicleType %> <br><span style="color:#71717a; font-family: monospace;">لوحة: <%= v.plateNumber %></span></td><td style="text-align:left; padding: 12px;"><form action="/system/custody/return" method="POST" onsubmit="return confirm('تأكيد سحب المركبة؟');" style="margin:0;"><input type="hidden" name="type" value="vehicle"><input type="hidden" name="index" value="<%= v.originalIndex %>"><button class="btn-secondary btn-compact" style="padding:6px 12px; font-size:11px; border:none;">استرجاع</button></form></td></tr><% }) %>
                            </table>
                        <% } %>
                    </div>
                </div>
            </div>
        </div>
    <% }) %>

    <script>
        const slider = document.getElementById('mainDragArea');
        let isDown = false; let startY; let scrollTop;
        slider.addEventListener('mousedown', (e) => { isDown = true; slider.style.cursor = 'grabbing'; startY = e.pageY - slider.offsetTop; scrollTop = slider.scrollTop; });
        slider.addEventListener('mouseleave', () => { isDown = false; slider.style.cursor = 'grab'; });
        slider.addEventListener('mouseup', () => { isDown = false; slider.style.cursor = 'grab'; });
        slider.addEventListener('mousemove', (e) => { if (!isDown) return; e.preventDefault(); const y = e.pageY - slider.offsetTop; const walk = (y - startY) * 1.5; slider.scrollTop = scrollTop - walk; });

        function filterTable(inputId, tableId) { const filter = document.getElementById(inputId).value.toLowerCase(); const rows = document.getElementById(tableId).getElementsByClassName('searchable-row'); for (let i = 0; i < rows.length; i++) { let text = rows[i].innerText.toLowerCase(); rows[i].style.display = text.includes(filter) ? "" : "none"; } }
        function openModal(id) { document.getElementById(id).style.display = 'block'; }
        function closeModal(id) { document.getElementById(id).style.display = 'none'; }
        window.onclick = function(event) { if (event.target.classList.contains('modal')) { event.target.style.display = "none"; } }
        function firePersonnel(userId) { let reason = prompt('الرجاء كتابة سبب الفصل لإضافته في السجل الشامل:'); if(reason !== null && reason.trim() !== "") { document.getElementById('fireReason_' + userId).value = reason; document.getElementById('fireForm_' + userId).submit(); } }
        
        window.onload = function() {
            const urlParams = new URLSearchParams(window.location.search);
            const openModalId = urlParams.get('open');
            if (openModalId) { const targetModal = document.getElementById('modal_profile_' + openModalId); if (targetModal) { targetModal.style.display = 'block'; } }
        };
    </script>
</body>
</html>