<!DOCTYPE html>
<html lang="ar">
<head>
    <meta charset="UTF-8">
    <title>إدارة العسكر والعهدة</title>
    <link rel="stylesheet" href="/style.css">
    <style>
        .profile-section { background: rgba(0,0,0,0.3); padding: 15px; border-radius: 10px; margin-bottom: 15px; border: 1px solid var(--glass-border); }
        .profile-section h3 { margin-bottom: 15px; font-size: 18px; border-bottom: 1px solid rgba(255,255,255,0.1); padding-bottom: 10px; }
        .cert-tag { background: rgba(155, 89, 182, 0.1); border: 1px solid #9B59B6; padding: 10px; border-radius: 8px; display: flex; align-items: center; gap: 15px; }
    </style>
</head>
<body>
    <%- include('partials/navbar') %>
    <div class="container fade-in">
        <a href="/system" class="btn-secondary" style="margin-bottom: 20px;">⬅️ العودة للوحة المركزية</a>
        
        <div class="card" style="border-color: var(--danger);">
            <h2 style="color: var(--danger); margin-bottom: 20px;">🎖️ إدارة العسكر (الترقيات، العهدة، والشهادات)</h2>
            <input type="text" id="searchPersonnel" class="search-bar" placeholder="🔍 ابحث بالاسم أو الآيدي..." onkeyup="filterTable('searchPersonnel', 'personnelTable')">
            
            <div class="scrollable-box" style="max-height: 600px;">
                <table id="personnelTable">
                    <tr class="header-row"><th>الاسم</th> <th>الرتبة</th> <th style="text-align:center;">الإجراءات</th></tr>
                    <% list.forEach(member => { %>
                        <tr class="searchable-row">
                            <td style="font-weight:bold; color:white;"><%= member.username %><br><span style="font-size:12px; color:gray;"><%= member.id %></span></td>
                            <td style="color:var(--warning); font-weight:bold;"><%= member.siteRank %><br><span style="color:var(--primary); font-weight:normal; font-size:12px;"><%= member.discordRank %></span></td>
                            <td style="text-align:center;">
                                <button type="button" class="btn-primary" style="padding: 8px 20px;" onclick="document.getElementById('modal_profile_<%= member.id %>').style.display='block'">ملف العسكري 📂</button>
                            </td>
                        </tr>
                    <% }) %>
                </table>
            </div>
        </div>
    </div>

    <% list.forEach(member => { 
        const memberWeapons = (custody.weaponLogs || []).map((l, i) => ({...l, originalIndex: i})).filter(l => l.receiverDiscordId === member.id);
        const memberVehicles = (custody.vehicleLogs || []).map((l, i) => ({...l, originalIndex: i})).filter(l => l.receiverDiscordId === member.id);
    %>
        <div id="modal_profile_<%= member.id %>" class="modal">
            <div class="modal-content" style="max-width: 800px; max-height: 90vh; overflow-y: auto;">
                <span class="close-btn" onclick="document.getElementById('modal_profile_<%= member.id %>').style.display='none'">&times;</span>
                <h2 style="color:white; margin-bottom:20px; text-align:center; border-bottom: 2px solid var(--danger); padding-bottom: 10px;">🗂️ ملف العسكري: <span style="color:var(--warning);"><%= member.username %></span></h2>
                
                <div class="profile-section" style="border-color: #9B59B6;">
                    <h3 style="color: #9B59B6;">🎖️ الشهادات والرخص الحاصل عليها</h3>
                    <% if(!member.certs || member.certs.length === 0) { %>
                        <p style="color:var(--text-muted); text-align:center;">لا توجد شهادات مسجلة لهذا العسكري.</p>
                    <% } else { %>
                        <div style="display:flex; gap:10px; flex-wrap:wrap;">
                            <% member.certs.forEach(cId => { %>
                                <div class="cert-tag">
                                    <span style="color: white; font-weight: bold;"><%= certTypes[cId] ? certTypes[cId].name : cId %></span>
                                    <form action="/system/personnel/revoke-cert" method="POST" onsubmit="return confirm('هل أنت متأكد من سحب هذه الشهادة من العسكري؟');" style="margin:0;">
                                        <input type="hidden" name="targetId" value="<%= member.id %>">
                                        <input type="hidden" name="certId" value="<%= cId %>">
                                        <button class="btn-danger" style="padding: 2px 8px; font-size: 11px;">سحب ❌</button>
                                    </form>
                                </div>
                            <% }) %>
                        </div>
                    <% } %>
                </div>

                <div class="profile-section" style="border-color: var(--danger);">
                    <h3 style="color: var(--danger);">📈 الترقيات والإجراءات الإدارية</h3>
                    <div style="display:flex; gap:10px; flex-wrap: wrap;">
                        <form action="/system/personnel/action" method="POST" style="flex:1; display:flex; gap:5px;"><input type="hidden" name="targetId" value="<%= member.id %>"><input type="hidden" name="action" value="update_discord"><select name="newDiscordRole" style="flex:1; padding: 8px;"><option value="enlisted" <%= member.discordRank === 'أفراد' ? 'selected' : '' %>>أفراد</option><option value="nco" <%= member.discordRank === 'ضباط صف' ? 'selected' : '' %>>ضباط صف</option><option value="officer" <%= member.discordRank === 'ضباط' ? 'selected' : '' %>>ضباط</option></select><button class="btn-primary">حفظ الفئة</button></form>
                        <form action="/system/personnel/action" method="POST" style="flex:1; display:flex; gap:5px;"><input type="hidden" name="targetId" value="<%= member.id %>"><input type="hidden" name="action" value="update_site"><select name="newSiteRank" style="flex:1; padding: 8px;"><% RANKS_LADDER.forEach(rank => { %><option value="<%= rank %>" <%= member.siteRank === rank ? 'selected' : '' %>><%= rank %></option><% }) %></select><button class="btn-warning" style="color:black; font-weight:bold;">حفظ الرتبة</button></form>
                        <form id="fireForm_<%= member.id %>" action="/system/personnel/action" method="POST" style="display:flex;"><input type="hidden" name="targetId" value="<%= member.id %>"><input type="hidden" name="action" value="fire"><input type="hidden" name="reason" id="fireReason_<%= member.id %>"><button type="button" class="btn-danger" onclick="firePersonnel('<%= member.id %>')">فصل من القطاع</button></form>
                    </div>
                </div>

                <div class="profile-section" style="border-color: #3498DB;">
                    <h3 style="color: #3498DB;">📦 صرف عهدة جديدة</h3>
                    <div style="display:flex; gap:20px; flex-wrap: wrap;">
                        <form action="/custody/weapons/issue" method="POST" style="flex:1; display:flex; flex-direction:column; gap:5px;">
                            <input type="hidden" name="discordId" value="<%= member.id %>"><input type="text" name="receiverName" value="<%= member.username %>" required placeholder="اسم العسكري" style="margin:0;"><input type="text" name="nationalId" required placeholder="الرقم الوطني" style="margin:0;"><select name="weaponType" required style="margin:0; padding: 10px; background: rgba(0,0,0,0.5); color: white;"><option value="" disabled selected>-- اختر السلاح --</option><% (custody.weaponTypes || []).forEach(type => { %> <option value="<%= type %>"><%= type %></option> <% }) %></select><input type="text" name="serialNumber" required placeholder="السيريال (S/N)" style="margin:0;"><button class="btn-primary" style="margin-top:5px;">صرف سلاح 🔫</button>
                        </form>
                        <form action="/custody/vehicles/issue" method="POST" style="flex:1; display:flex; flex-direction:column; gap:5px;">
                            <input type="hidden" name="discordId" value="<%= member.id %>"><input type="text" name="receiverName" value="<%= member.username %>" required placeholder="اسم العسكري" style="margin:0;"><input type="text" name="nationalId" required placeholder="الرقم الوطني" style="margin:0;"><select name="vehicleType" required style="margin:0; padding: 10px; background: rgba(0,0,0,0.5); color: white;"><option value="" disabled selected>-- اختر المركبة --</option><% (custody.vehicleTypes || []).forEach(type => { %> <option value="<%= type %>"><%= type %></option> <% }) %></select><input type="text" name="plateNumber" required placeholder="رقم اللوحة" style="margin:0;"><button class="btn-warning" style="margin-top:5px; color:black;">صرف مركبة 🚓</button>
                        </form>
                    </div>
                </div>

                <div class="profile-section" style="border-color: #F1C40F;">
                    <h3 style="color: #F1C40F;">📋 العهدة المسجلة حالياً</h3>
                    <% if(memberWeapons.length === 0 && memberVehicles.length === 0) { %>
                        <p style="color:var(--text-muted); text-align:center;">لا توجد عهدة مسجلة.</p>
                    <% } else { %>
                        <table style="background: rgba(0,0,0,0.2); width:100%;">
                            <% memberWeapons.forEach(w => { %>
                                <tr>
                                    <td style="color:white;">🔫 <%= w.weaponType %> <br><span style="color:gray; font-size:12px;">S/N: <%= w.serialNumber %></span></td>
                                    <td style="text-align:left;"><form action="/system/custody/return" method="POST" onsubmit="return confirm('تأكيد سحب السلاح؟');"><input type="hidden" name="type" value="weapon"><input type="hidden" name="index" value="<%= w.originalIndex %>"><button class="btn-secondary" style="padding:5px 10px; font-size:12px;">استرجاع</button></form></td>
                                </tr>
                            <% }) %>
                            <% memberVehicles.forEach(v => { %>
                                <tr>
                                    <td style="color:white;">🚓 <%= v.vehicleType %> <br><span style="color:gray; font-size:12px;">لوحة: <%= v.plateNumber %></span></td>
                                    <td style="text-align:left;"><form action="/system/custody/return" method="POST" onsubmit="return confirm('تأكيد سحب المركبة؟');"><input type="hidden" name="type" value="vehicle"><input type="hidden" name="index" value="<%= v.originalIndex %>"><button class="btn-secondary" style="padding:5px 10px; font-size:12px;">استرجاع</button></form></td>
                                </tr>
                            <% }) %>
                        </table>
                    <% } %>
                </div>

            </div>
        </div>
    <% }) %>

    <script>
        function filterTable(inputId, tableId) { const filter = document.getElementById(inputId).value.toLowerCase(); const rows = document.getElementById(tableId).getElementsByClassName('searchable-row'); for (let i = 0; i < rows.length; i++) { let text = rows[i].innerText.toLowerCase(); rows[i].style.display = text.includes(filter) ? "" : "none"; } }
        window.onclick = function(event) { if (event.target.classList.contains('modal')) { event.target.style.display = "none"; } }
        function firePersonnel(userId) { let reason = prompt('سبب الفصل؟'); if(reason !== null) { document.getElementById('fireReason_' + userId).value = reason; document.getElementById('fireForm_' + userId).submit(); } }
    </script>
</body>
</html>