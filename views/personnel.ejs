<!DOCTYPE html>
<html lang="ar">
<head>
  <meta charset="UTF-8">
  <title>إدارة العسكر والعهدة</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <%- include('partials/navbar') %>

  <div class="container fade-in">
    <a href="/system" class="btn-secondary" style="margin-bottom: 20px; display: inline-block;">⬅️ العودة للوحة المركزية</a>

    <div class="card" style="border-color: var(--danger);">
      <h2 style="color: var(--danger); margin-bottom: 20px;">🎖️ سجل الأفراد والضباط</h2>

      <input
        type="text"
        id="searchPersonnel"
        class="search-bar"
        placeholder="🔍 ابحث بالاسم، الآيدي، أو الرقم الوطني..."
        onkeyup="filterTable('searchPersonnel', 'personnelTable')"
      >

      <div class="scrollable-box" style="max-height: 70vh;">
        <table id="personnelTable" style="margin: 0; width: 100%;">
          <tr class="header-row">
            <th>العسكري</th>
            <th>الرتبة</th>
            <th style="text-align:center;">الإجراءات</th>
          </tr>

          <% list.forEach(member => { %>
            <tr class="searchable-row">
              <td style="font-weight:bold; color:#e4e4e7;">
                <%= member.realName %><br>
                <span style="font-size:11px; color:#a1a1aa;">
                  ديسكورد: <%= member.username %> | آيدي: <%= member.id %>
                </span><br>
                <span style="font-size:12px; color:var(--primary);">
                  الرقم الوطني: <%= member.nationalId %>
                </span>
              </td>

              <td style="color:var(--warning); font-weight:bold;">
                <%= member.siteRank %><br>
                <span style="color:#a1a1aa; font-weight:normal; font-size:11px;">
                  شريحة: <%= member.discordRank %>
                </span>
              </td>

              <td style="text-align:center;">
                <a href="/system/personnel/<%= member.id %>" class="btn-primary" style="display:inline-block;">
                  فتح الملف 📂
                </a>
              </td>
            </tr>
          <% }) %>
        </table>
      </div>
    </div>
  </div>

  <script>
    function filterTable(inputId, tableId) {
      const filter = document.getElementById(inputId).value.toLowerCase();
      const rows = document.getElementById(tableId).getElementsByClassName('searchable-row');

      for (let i = 0; i < rows.length; i++) {
        let text = rows[i].innerText.toLowerCase();
        rows[i].style.display = text.includes(filter) ? "" : "none";
      }
    }
  </script>
</body>
</html>