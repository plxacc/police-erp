<!DOCTYPE html>
<html lang="ar">
<head>
    <meta charset="UTF-8">
    <title>إدارة العسكر والعهدة</title>
    <link rel="stylesheet" href="/style.css">
    <style>
        /* 🚀 تحسينات الفريمات والأداء */
        .modal { background-color: rgba(0, 0, 0, 0.8) !important; backdrop-filter: blur(5px) !important; }
        .modal-content { background: #121212 !important; border: 1px solid #27272a; border-radius: 16px; box-shadow: 0 20px 50px rgba(0,0,0,0.9) !important; padding: 20px 25px; }
        
        .profile-section { padding: 16px; border-radius: 12px; margin-bottom: 20px; border: 1px solid #27272a; border-right-width: 4px; transition: 0.3s; }
        .section-purple { background: rgba(155, 89, 182, 0.03); border-right-color: #9B59B6; }
        .section-red { background: rgba(231, 76, 60, 0.03); border-right-color: #e74c3c; }
        .section-blue { background: rgba(52, 152, 219, 0.03); border-right-color: #3498DB; }

        /* 🖱️ منطقة التحرك الحر بالماوس */
        .drag-area {
            overflow: auto;
            cursor: grab;
            max-height: 650px;
            border-radius: 12px;
            border: 1px solid #27272a;
            user-select: none; /* منع تحديد النص أثناء السحب */
        }
        .drag-area:active { cursor: grabbing; }

        .form-control { width: 100%; padding: 8px 12px; background: #09090b; border: 1px solid #3f3f46; color: white; border-radius: 6px; }
        .badge-custom { padding: 6px 14px; border-radius: 20px; font-size: 12px; font-weight: bold; background: #27272a; border: 1px solid #3f3f46; color: #d4d4d8; }
    </style>
</head>
<body>
    <%- include('partials/navbar') %>
    <div class="container fade-in">
        <a href="/system" class="btn-secondary" style="margin-bottom: 20px; display: inline-block;">⬅️ العودة للوحة المركزية</a>
        
        <div class="card" style="border-color: var(--danger); background: rgba(0,0,0,0.3);">
            <h2 style="color: var(--danger); margin-bottom: 20px;">🎖️ سجل الأفراد والضباط</h2>
            <input type="text" id="searchPersonnel" class="search-bar form-control" style="font-size: 15px; padding: 12px; margin-bottom: 20px;" placeholder="🔍 ابحث بالاسم، الآيدي، الرقم الوطني، أو الكود العسكري..." onkeyup="filterTable('searchPersonnel', 'personnelTable')">
            
            <div class="drag-area" id="mainDragArea">
                <table id="personnelTable" style="margin: 0; background: #18181b; width: 100%;">
                    <tr class="header-row" style="background: #27272a;">
                        <th style="padding: 15px;">العسكري</th> 
                        <th style="padding: 15px;">الرتبة والكود</th> 
                        <th style="text-align:center; padding: 15px;">الإجراءات</th>
                    </tr>
                    <% list.forEach(member => { %>
                        <tr class="searchable-row" style="border-bottom: 1px solid #27272a;">
                            <td style="font-weight:bold; color:#e4e4e7; padding: 15px;">
                                <%= member.realName %> <br>
                                <span style="font-size:11px; color:#a1a1aa;">ديسكورد: <%= member.username %></span>
                            </td>
                            <td style="color:var(--warning); font-weight:bold; padding: 15px;">
                                <%= member.siteRank %> <br>
                                <span style="color:#3498DB; font-size:12px;">🔢 <%= member.militaryCode || 'غير مسجل' %></span>
                            </td>
                            <td style="text-align:center; padding: 15px;">
                                <button type="button" class="btn-primary" onclick="openModal('modal_profile_<%= member.id %>')">فتح الملف 📂</button>
                            </td>
                        </tr>
                    <% }) %>
                </table>
            </div>
        </div>
    </div>

    <% 
        // تجميع العهدة لزيادة السرعة
        let weaponsMap = {}; let vehiclesMap = {};
        (custody.weaponLogs || []).forEach((l, i) => { if(!weaponsMap[l.receiverDiscordId]) weaponsMap[l.receiverDiscordId] = []; weaponsMap[l.receiverDiscordId].push({...l, originalIndex: i}); });
        (custody.vehicleLogs || []).forEach((l, i) => { if(!vehiclesMap[l.receiverDiscordId]) vehiclesMap[l.receiverDiscordId] = []; vehiclesMap[l.receiverDiscordId].push({...l, originalIndex: i}); });
    %>

    <% list.forEach(member => { 
        const memberWeapons = weaponsMap[member.id] || [];
        const memberVehicles = vehiclesMap[member.id] || [];
    %>
        <div id="modal_profile_<%= member.id %>" class="modal">
            <div class="modal-content">
                <span class="close-btn" onclick="closeModal('modal_profile_<%= member.id %>')" style="position:absolute; top: 15px; right: 20px; cursor:pointer;">&times;</span>
                
                <div style="text-align:center; padding-bottom: 15px; margin-bottom:20px; border-bottom: 1px solid #27272a;">
                    <h2 style="color:#f4f4f5; font-size: 22px;">🗂️ ملف العسكري: <span style="color:var(--warning);"><%= member.realName %></span></h2>
                    <div class="badge-group" style="display:flex; justify-content:center; gap:10px; margin-top:10px;">
                        <span class="badge-custom">🔢 كود: <%= member.militaryCode || 'بدون' %></span>
                        <span class="badge-custom">📅 انضمام: <%= member.joinDate || 'قديم' %></span>
                    </div>
                </div>
                
                <div class="profile-section section-purple">
                    <h3 style="color: #c084fc;">🎖️ الشهادات والرخص</h3>
                    <div style="display:flex; gap:8px; flex-wrap:wrap; margin-bottom: 10px;">
                        <% if(member.certs && member.certs.length > 0) { member.certs.forEach(cId => { %>
                            <div class="badge-custom" style="border-color:#9B59B6;"><%= certTypes[cId]?.name || cId %></div>
                        <% })} else { %> <p style="color:gray; font-size:12px;">لا توجد شهادات.</p> <% } %>
                    </div>
                    <form action="/system/personnel/grant-cert-direct" method="POST" style="display:flex; gap:10px;">
                        <input type="hidden" name="targetId" value="<%= member.id %>">
                        <select name="certId" required class="form-control"><option value="" disabled selected>منح شهادة مباشرة</option><% Object.entries(certTypes).forEach(([cId, cInfo]) => { %> <option value="<%= cId %>"><%= cInfo.name %></option> <% }) %></select>
                        <button type="submit" class="btn-success">منح 📜</button>
                    </form>
                </div>

                <div class="profile-section section-red">
                    <h3 style="color: #f87171;">⚙️ الإجراءات الإدارية</h3>
                    <form action="/system/personnel/action" method="POST" style="display:grid; grid-template-columns: 1fr 1fr; gap:10px;">
                        <input type="hidden" name="targetId" value="<%= member.id %>"><input type="hidden" name="action" value="update_site">
                        <input type="text" name="newRealName" value="<%= member.realName %>" class="form-control" placeholder="الاسم">
                        <input type="text" name="newCode" value="<%= member.militaryCode %>" class="form-control" placeholder="الكود">
                        <select name="newSiteRank" class="form-control"><% RANKS_LADDER.forEach(rank => { %><option value="<%= rank %>" <%= member.siteRank === rank ? 'selected' : '' %>><%= rank %></option><% }) %></select>
                        <button type="submit" class="btn-warning">حفظ 💾</button>
                    </form>
                    <button class="btn-danger" style="width:100%; margin-top:10px;" onclick="firePersonnel('<%= member.id %>')">فصل من القطاع ❌</button>
                </div>
            </div>
        </div>
    <% }) %>

    <script>
        // 🖱️ سكربت التحرك بالسحب (Drag to Scroll)
        const setupDragScroll = (elId) => {
            const slider = document.getElementById(elId);
            let isDown = false; let startY; let scrollTop;
            slider.addEventListener('mousedown', (e) => { isDown = true; slider.style.cursor = 'grabbing'; startY = e.pageY - slider.offsetTop; scrollTop = slider.scrollTop; });
            slider.addEventListener('mouseleave', () => { isDown = false; slider.style.cursor = 'grab'; });
            slider.addEventListener('mouseup', () => { isDown = false; slider.style.cursor = 'grab'; });
            slider.addEventListener('mousemove', (e) => { if (!isDown) return; e.preventDefault(); const y = e.pageY - slider.offsetTop; const walk = (y - startY) * 1.5; slider.scrollTop = scrollTop - walk; });
        }
        setupDragScroll('mainDragArea');

        function filterTable(inputId, tableId) { const filter = document.getElementById(inputId).value.toLowerCase(); const rows = document.getElementById(tableId).getElementsByClassName('searchable-row'); for (let i = 0; i < rows.length; i++) { let text = rows[i].innerText.toLowerCase(); rows[i].style.display = text.includes(filter) ? "" : "none"; } }
        function openModal(id) { document.getElementById(id).style.display = 'block'; }
        function closeModal(id) { document.getElementById(id).style.display = 'none'; }
        window.onclick = function(event) { if (event.target.classList.contains('modal')) { event.target.style.display = "none"; } }
        function firePersonnel(userId) { let reason = prompt('سبب الفصل:'); if(reason) { /* إرسال الفورم هنا */ } }
    </script>
</body>
</html>