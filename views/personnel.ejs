<!DOCTYPE html>
<html lang="ar">
<head>
    <meta charset="UTF-8">
    <title>إدارة العسكر والعهدة المطورة</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <%- include('partials/navbar') %>
    <div class="container fade-in">
        <div class="card" style="border-color: var(--primary);">
            <h2 style="color: var(--primary); margin-bottom: 20px;">🔍 نظام البحث والاستعلام العسكري</h2>
            <input type="text" id="searchPersonnel" class="search-bar" 
                   placeholder="🔍 ابحث بالاسم، الرقم العسكري (Discord ID)، أو الرقم الوطني..." 
                   onkeyup="advancedFilter()">
            
            <div class="scrollable-box" style="max-height: 600px; margin-top: 20px;">
                <table id="personnelTable">
                    <tr class="header-row">
                        <th>بيانات العسكري</th>
                        <th>الرتبة</th>
                        <th>الرقم الوطني</th>
                        <th style="text-align:center;">الإجراءات</th>
                    </tr>
                    <% list.forEach(member => { %>
                        <tr class="searchable-row">
                            <td style="font-weight:bold; color:white;">
                                <%= member.fullName || member.username %> 
                                <br><span style="font-size:11px; color:var(--primary);">ID: <%= member.id %></span>
                            </td>
                            <td style="color:var(--warning); font-weight:bold;"><%= member.siteRank %></td>
                            <td class="nat-id" style="color:#aaa;"><%= member.nationalId || 'غير مسجل' %></td>
                            <td style="text-align:center;">
                                <button class="btn-primary" onclick="document.getElementById('modal_profile_<%= member.id %>').style.display='block'">فتح السجل الكامل 📂</button>
                            </td>
                        </tr>
                    <% }) %>
                </table>
            </div>
        </div>
    </div>

    <% list.forEach(member => { %>
        <div id="modal_profile_<%= member.id %>" class="modal">
            <div class="modal-content" style="max-width: 850px;">
                <span class="close-btn" onclick="document.getElementById('modal_profile_<%= member.id %>').style.display='none'">&times;</span>
                
                <h2 style="text-align:center; color:var(--warning);">بطاقة البيانات العسكرية</h2>
                
                <div class="profile-section" style="border-color: var(--primary);">
                    <h3 style="color: var(--primary);">🆔 البيانات التعريفية (تحديث)</h3>
                    <form action="/system/personnel/update-info" method="POST" style="display:grid; grid-template-columns: 1fr 1fr auto; gap:10px;">
                        <input type="hidden" name="targetId" value="<%= member.id %>">
                        <input type="text" name="fullName" value="<%= member.fullName || '' %>" placeholder="الاسم الثنائي العسكري" required>
                        <input type="text" name="nationalId" value="<%= member.nationalId || '' %>" placeholder="الرقم الوطني" required>
                        <button class="btn-success">حفظ البيانات ✅</button>
                    </form>
                </div>

                </div>
        </div>
    <% }) %>

    <script>
        function advancedFilter() {
            const filter = document.getElementById('searchPersonnel').value.toLowerCase();
            const rows = document.querySelectorAll('.searchable-row');
            
            rows.forEach(row => {
                const text = row.innerText.toLowerCase();
                // البحث الذكي في كل محتوى السطر
                row.style.display = text.includes(filter) ? "" : "none";
            });
        }
    </script>
</body>
</html>