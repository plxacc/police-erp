<!DOCTYPE html>
<html lang="ar">
<head>
    <meta charset="UTF-8">
    <title>إدارة العسكر</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <%- include('partials/navbar') %>
    <div class="container fade-in">
        <a href="/system" class="btn-secondary" style="margin-bottom: 20px; display: inline-block;">⬅️ العودة للوحة المركزية</a>
        
        <div class="card" style="border-top-color: var(--danger);">
            <h2 style="color: var(--danger); margin-bottom: 20px; font-weight: 900;">🎖️ سجل الأفراد والضباط</h2>
            <input type="text" id="searchPersonnel" class="search-bar" placeholder="🔍 ابحث بالاسم، الآيدي، الرقم الوطني، أو الكود العسكري..." onkeyup="filterTable('searchPersonnel', 'personnelTable')">
            
            <div class="drag-scroll" id="mainDragArea">
                <table id="personnelTable">
                    <tr>
                        <th>العسكري</th> 
                        <th>الرتبة</th> 
                        <th style="text-align:center;">الإجراءات</th>
                    </tr>
                    <% list.forEach(member => { %>
                        <tr class="searchable-row">
                            <td style="font-weight:bold; color:var(--text-main);">
                                <%= member.realName %> <br>
                                <span style="font-size:12px; color:var(--text-muted);">ديسكورد: <%= member.username %> | آيدي: <%= member.id %></span><br>
                                <span style="font-size:12px; color:var(--primary);">الرقم الوطني: <%= member.nationalId %></span>
                            </td>
                            <td style="color:var(--warning); font-weight:bold;">
                                <%= member.siteRank %> <br>
                                <span style="font-size:12px; color:var(--text-muted);">شريحة: <%= member.discordRank %></span>
                            </td>
                            <td style="text-align:center;">
                                <a href="/system/personnel/<%= member.id %>" class="btn-primary" style="display: inline-block;">فتح الملف 📂</a>
                            </td>
                        </tr>
                    <% }) %>
                </table>
            </div>
        </div>
    </div>

    <script>
        function filterTable(inputId, tableId) { const filter = document.getElementById(inputId).value.toLowerCase(); const rows = document.getElementById(tableId).getElementsByClassName('searchable-row'); for (let i = 0; i < rows.length; i++) { let text = rows[i].innerText.toLowerCase(); rows[i].style.display = text.includes(filter) ? "" : "none"; } }
        
        // 🖱️ ميزة السحب بالماوس
        const slider = document.getElementById('mainDragArea');
        let isDown = false; let startY; let scrollTop;
        slider.addEventListener('mousedown', (e) => { isDown = true; slider.style.cursor = 'grabbing'; startY = e.pageY - slider.offsetTop; scrollTop = slider.scrollTop; });
        slider.addEventListener('mouseleave', () => { isDown = false; slider.style.cursor = 'grab'; });
        slider.addEventListener('mouseup', () => { isDown = false; slider.style.cursor = 'grab'; });
        slider.addEventListener('mousemove', (e) => { if (!isDown) return; e.preventDefault(); const y = e.pageY - slider.offsetTop; const walk = (y - startY) * 1.5; slider.scrollTop = scrollTop - walk; });
    </script>
</body>
</html>