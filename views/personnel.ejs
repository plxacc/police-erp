<!DOCTYPE html>
<html lang="ar">
<head>
    <meta charset="UTF-8">
    <title>إدارة العسكر والعهدة</title>
    <link rel="stylesheet" href="/style.css">
    <style>
        /* 🚀 أكواد تسريع الأداء ومنع اللاق */
        .modal { background-color: rgba(0, 0, 0, 0.85) !important; backdrop-filter: none !important; }
        .modal-content { background: #121212 !important; backdrop-filter: none !important; border: 1px solid #333; border-radius: 12px; box-shadow: 0 10px 40px rgba(0,0,0,0.9) !important; will-change: transform, opacity; transform: translateZ(0); padding: 25px; }
        
        /* 🎨 تنسيقات الأقسام الجديدة (التنظيم) */
        .profile-section { background: #1a1a1a !important; padding: 20px; border-radius: 10px; margin-bottom: 25px; border: 1px solid #2c2c2c !important; }
        .profile-section h3 { margin-bottom: 20px; font-size: 18px; border-bottom: 2px solid #333; padding-bottom: 10px; }
        
        .form-grid { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 15px; }
        .form-grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 15px; }
        .form-control { width: 100%; padding: 10px; background: #0a0a0a; border: 1px solid #444; color: white; border-radius: 6px; box-sizing: border-box; }
        .form-control:focus { border-color: var(--primary); outline: none; }
        .btn-block { width: 100%; display: block; margin-top: 10px; padding: 10px; font-size: 14px; }
        
        .cert-tag { background: #2c1a33; border: 1px solid #9B59B6; padding: 10px 15px; border-radius: 8px; display: flex; align-items: center; gap: 15px; }
        .badge-group { display: flex; gap: 10px; flex-wrap: wrap; justify-content: center; margin-top: 15px; }
        .badge-custom { padding: 8px 15px; border-radius: 6px; font-size: 13px; font-weight: bold; background: #222; border: 1px solid #444; color: #ddd; }
        
        .inner-box { background: rgba(255,255,255,0.02); padding: 15px; border-radius: 8px; border: 1px solid #333; }
        .inner-label { color:gray; font-size:12px; display:block; margin-bottom:8px; font-weight: bold; }
    </style>
</head>
<body>
    <%- include('partials/navbar') %>
    <div class="container fade-in">
        <a href="/system" class="btn-secondary" style="margin-bottom: 20px;">⬅️ العودة للوحة المركزية</a>
        
        <div class="card" style="border-color: var(--danger);">
            <h2 style="color: var(--danger); margin-bottom: 20px;">🎖️ سجل الأفراد والضباط</h2>
            <input type="text" id="searchPersonnel" class="search-bar" placeholder="🔍 ابحث بالاسم، الآيدي، الرقم الوطني، أو الكود العسكري..." onkeyup="filterTable('searchPersonnel', 'personnelTable')">
            
            <div class="scrollable-box" style="max-height: 600px;">
                <table id="personnelTable">
                    <tr class="header-row"><th>العسكري</th> <th>الرتبة والكود</th> <th style="text-align:center;">الإجراءات</th></tr>
                    <% list.forEach(member => { %>
                        <tr class="searchable-row">
                            <td style="font-weight:bold; color:white;">
                                <%= member.realName %> <br>
                                <span style="font-size:11px; color:gray;">ديسكورد: <%= member.username %> | آيدي: <%= member.id %></span><br>
                                <span style="font-size:12px; color:var(--primary);">الرقم الوطني: <%= member.nationalId %></span>
                            </td>
                            <td style="color:var(--warning); font-weight:bold;">
                                <%= member.siteRank %> <br>
                                <span style="color:#3498DB; font-size:13px;">كود عسكري: <%= member.militaryCode || 'غير مسجل' %></span><br>
                                <span style="color:gray; font-weight:normal; font-size:11px;">شريحة: <%= member.discordRank %></span>
                            </td>
                            <td style="text-align:center;">
                                <button type="button" class="btn-primary" style="padding: 8px 20px;" onclick="document.getElementById('modal_profile_<%= member.id %>').style.display='block'">ملف العسكري 📂</button>
                            </td>
                        </tr>
                    <% }) %>
                </table>
            </div>
        </div>
    </div>

    <% list.forEach(member => { 
        const memberWeapons = (custody.weaponLogs || []).map((l, i) => ({...l, originalIndex: i})).filter(l => l.receiverDiscordId === member.id);
        const memberVehicles = (custody.vehicleLogs || []).map((l, i) => ({...l, originalIndex: i})).filter(l => l.receiverDiscordId === member.id);
    %>
        <div id="modal_profile_<%= member.id %>" class="modal">
            <div class="modal-content" style="max-width: 850px; max-height: 90vh; overflow-y: auto;">
                <span class="close-btn" onclick="document.getElementById('modal_profile_<%= member.id %>').style.display='none'">&times;</span>
                
                <div style="text-align:center; padding-bottom: 20px; margin-bottom:25px; border-bottom: 2px solid #333;">
                    <h2 style="color:white; margin-bottom:10px;">🗂️ ملف العسكري: <span style="color:var(--warning);"><%= member.realName %></span></h2>
                    <div class="badge-group">
                        <span class="badge-custom" style="color:#3498DB; border-color:#3498DB;">🔢 كود: <%= member.militaryCode || 'بدون' %></span>
                        <span class="badge-custom" style="color:#2ecc71; border-color:#2ecc71;">📅 انضمام: <%= member.joinDate || 'قديم' %></span>
                        <span class="badge-custom" style="color:#9B59B6; border-color:#9B59B6;">🕒 آخر دخول: <%= member.lastLogin || 'غير معروف' %></span>
                    </div>
                </div>
                
                <div class="profile-section" style="border-top: 3px solid #9B59B6;">
                    <h3 style="color: #9B59B6;">🎖️ الشهادات والرخص الحاصل عليها</h3>
                    
                    <% if(!member.certs || member.certs.length === 0) { %>
                        <p style="color:var(--text-muted); text-align:center; padding: 10px 0;">لا توجد شهادات مسجلة لهذا العسكري.</p>
                    <% } else { %>
                        <div style="display:flex; gap:10px; flex-wrap:wrap; margin-bottom: 20px;">
                            <% member.certs.forEach(cId => { %>
                                <div class="cert-tag">
                                    <span style="color: white; font-weight: bold;"><%= certTypes[cId] ? certTypes[cId].name : cId %></span>
                                    <form action="/system/personnel/revoke-cert" method="POST" onsubmit="return confirm('سحب الشهادة؟');" style="margin:0;">
                                        <input type="hidden" name="targetId" value="<%= member.id %>"><input type="hidden" name="certId" value="<%= cId %>">
                                        <button class="btn-danger" style="padding: 4px 10px; font-size: 11px;">سحب ❌</button>
                                    </form>
                                </div>
                            <% }) %>
                        </div>
                    <% } %>
                    
                    <div class="inner-box">
                        <span class="inner-label">منح شهادة استثنائية (مباشرة)</span>
                        <form action="/system/personnel/grant-cert-direct" method="POST" style="display:flex; gap:10px;">
                            <input type="hidden" name="targetId" value="<%= member.id %>">
                            <select name="certId" required class="form-control" style="flex:1;">
                                <option value="" disabled selected>-- اختر شهادة لمنحها مباشرة --</option>
                                <% Object.entries(certTypes).forEach(([cId, cInfo]) => { %> <option value="<%= cId %>"><%= cInfo.name %></option> <% }) %>
                            </select>
                            <button type="submit" class="btn-success" style="padding: 0 20px;" onclick="return confirm('تأكيد منح الشهادة مباشرة؟');">منح 📜</button>
                        </form>
                    </div>
                </div>

                <div class="profile-section" style="border-top: 3px solid var(--danger);">
                    <h3 style="color: var(--danger);">⚙️ الإجراءات الإدارية والترقيات</h3>
                    
                    <div class="form-grid-2">
                        <div class="inner-box">
                            <span class="inner-label">شريحة الديسكورد</span>
                            <form action="/system/personnel/action" method="POST" style="display:flex; gap:5px;">
                                <input type="hidden" name="targetId" value="<%= member.id %>">
                                <input type="hidden" name="action" value="update_discord">
                                <select name="newDiscordRole" class="form-control">
                                    <option value="enlisted" <%= member.discordRank === 'أفراد' ? 'selected' : '' %>>أفراد</option>
                                    <option value="nco" <%= member.discordRank === 'ضباط صف' ? 'selected' : '' %>>ضباط صف</option>
                                    <option value="officer" <%= member.discordRank === 'ضباط' ? 'selected' : '' %>>ضباط</option>
                                </select>
                                <button class="btn-primary" style="padding: 0 15px;">حفظ</button>
                            </form>
                        </div>
                        
                        <div class="inner-box">
                            <span class="inner-label">الكود العسكري</span>
                            <form action="/system/personnel/action" method="POST" style="display:flex; gap:5px;">
                                <input type="hidden" name="targetId" value="<%= member.id %>">
                                <input type="hidden" name="action" value="update_code">
                                <input type="text" name="newCode" required placeholder="مثال: 1050" value="<%= member.militaryCode %>" class="form-control">
                                <button type="submit" class="btn-primary" style="padding: 0 15px;">حفظ 🔄</button>
                            </form>
                        </div>
                    </div>

                    <div class="inner-box" style="margin-top: 15px; margin-bottom: 15px;">
                        <span class="inner-label">بيانات النظام والرتبة العسكرية</span>
                        <form action="/system/personnel/action" method="POST">
                            <input type="hidden" name="targetId" value="<%= member.id %>">
                            <input type="hidden" name="action" value="update_site">
                            <div class="form-grid">
                                <input type="text" name="newRealName" value="<%= member.realName %>" placeholder="الاسم الثنائي" required class="form-control">
                                <input type="text" name="newNationalId" value="<%= member.nationalId %>" placeholder="الرقم الوطني" required class="form-control">
                                <select name="newSiteRank" class="form-control">
                                    <% RANKS_LADDER.forEach(rank => { %>
                                        <option value="<%= rank %>" <%= member.siteRank === rank ? 'selected' : '' %>><%= rank %></option>
                                    <% }) %>
                                </select>
                            </div>
                            <button class="btn-warning btn-block" style="color:black; font-weight:bold;">حفظ بيانات النظام 💾</button>
                        </form>
                    </div>

                    <form id="fireForm_<%= member.id %>" action="/system/personnel/action" method="POST">
                        <input type="hidden" name="targetId" value="<%= member.id %>"><input type="hidden" name="action" value="fire"><input type="hidden" name="reason" id="fireReason_<%= member.id %>">
                        <button type="button" class="btn-danger btn-block" onclick="firePersonnel('<%= member.id %>')">فصل وطي قيد من القطاع ❌</button>
                    </form>
                </div>

                <div class="profile-section" style="border-top: 3px solid #3498DB;">
                    <h3 style="color: #3498DB;">📦 صرف واسترجاع العهدة</h3>
                    
                    <div class="form-grid-2">
                        <div class="inner-box">
                            <h4 style="color:#3498DB; margin-bottom:15px; font-size:14px; text-align:center;">🔫 صرف سلاح</h4>
                            <form action="/custody/weapons/issue" method="POST">
                                <input type="hidden" name="discordId" value="<%= member.id %>">
                                <input type="hidden" name="receiverName" value="<%= member.realName %>">
                                <input type="hidden" name="nationalId" value="<%= member.nationalId %>">
                                <select name="weaponType" required class="form-control" style="margin-bottom:10px;">
                                    <option value="" disabled selected>-- اختر السلاح --</option>
                                    <% (custody.weaponTypes || []).forEach(type => { %> <option value="<%= type %>"><%= type %></option> <% }) %>
                                </select>
                                <input type="text" name="serialNumber" required placeholder="السيريال (S/N)" class="form-control" style="margin-bottom:10px;">
                                <button class="btn-primary btn-block">صرف السلاح</button>
                            </form>
                        </div>
                        
                        <div class="inner-box">
                            <h4 style="color:#F1C40F; margin-bottom:15px; font-size:14px; text-align:center;">🚓 صرف مركبة</h4>
                            <form action="/custody/vehicles/issue" method="POST">
                                <input type="hidden" name="discordId" value="<%= member.id %>">
                                <input type="hidden" name="receiverName" value="<%= member.realName %>">
                                <input type="hidden" name="nationalId" value="<%= member.nationalId %>">
                                <select name="vehicleType" required class="form-control" style="margin-bottom:10px;">
                                    <option value="" disabled selected>-- اختر المركبة --</option>
                                    <% (custody.vehicleTypes || []).forEach(type => { %> <option value="<%= type %>"><%= type %></option> <% }) %>
                                </select>
                                <input type="text" name="plateNumber" required placeholder="رقم اللوحة" class="form-control" style="margin-bottom:10px;">
                                <button class="btn-warning btn-block" style="color:black;">صرف المركبة</button>
                            </form>
                        </div>
                    </div>

                    <div style="margin-top: 20px;">
                        <span class="inner-label" style="color:#F1C40F; margin-bottom:10px;">📋 العهدة المسجلة حالياً:</span>
                        <% if(memberWeapons.length === 0 && memberVehicles.length === 0) { %>
                            <p style="color:var(--text-muted); text-align:center; padding: 10px; background: rgba(0,0,0,0.3); border-radius: 8px;">لا توجد عهدة مسجلة.</p>
                        <% } else { %>
                            <table style="background: rgba(0,0,0,0.4); width:100%; border-radius:8px; overflow:hidden;">
                                <% memberWeapons.forEach(w => { %>
                                    <tr style="border-bottom: 1px solid #333;">
                                        <td style="color:white; padding: 10px;">🔫 <%= w.weaponType %> <br><span style="color:gray; font-size:12px;">S/N: <%= w.serialNumber %></span></td>
                                        <td style="text-align:left; padding: 10px;"><form action="/system/custody/return" method="POST" onsubmit="return confirm('تأكيد سحب السلاح؟');" style="margin:0;"><input type="hidden" name="type" value="weapon"><input type="hidden" name="index" value="<%= w.originalIndex %>"><button class="btn-secondary" style="padding:6px 12px; font-size:12px;">استرجاع</button></form></td>
                                    </tr>
                                <% }) %>
                                <% memberVehicles.forEach(v => { %>
                                    <tr style="border-bottom: 1px solid #333;">
                                        <td style="color:white; padding: 10px;">🚓 <%= v.vehicleType %> <br><span style="color:gray; font-size:12px;">لوحة: <%= v.plateNumber %></span></td>
                                        <td style="text-align:left; padding: 10px;"><form action="/system/custody/return" method="POST" onsubmit="return confirm('تأكيد سحب المركبة؟');" style="margin:0;"><input type="hidden" name="type" value="vehicle"><input type="hidden" name="index" value="<%= v.originalIndex %>"><button class="btn-secondary" style="padding:6px 12px; font-size:12px;">استرجاع</button></form></td>
                                    </tr>
                                <% }) %>
                            </table>
                        <% } %>
                    </div>
                </div>
            </div>
        </div>
    <% }) %>

    <script>
        function filterTable(inputId, tableId) { const filter = document.getElementById(inputId).value.toLowerCase(); const rows = document.getElementById(tableId).getElementsByClassName('searchable-row'); for (let i = 0; i < rows.length; i++) { let text = rows[i].innerText.toLowerCase(); rows[i].style.display = text.includes(filter) ? "" : "none"; } }
        window.onclick = function(event) { if (event.target.classList.contains('modal')) { event.target.style.display = "none"; } }
        function firePersonnel(userId) { let reason = prompt('الرجاء كتابة سبب الفصل لإضافته في السجل الشامل:'); if(reason !== null && reason.trim() !== "") { document.getElementById('fireReason_' + userId).value = reason; document.getElementById('fireForm_' + userId).submit(); } else if(reason !== null) { alert('يجب كتابة سبب الفصل لحفظه في السجل!'); } }
        // 🚀 كود ذكي: يفتح ملف العسكري مباشرة إذا جاء الضابط من رابط فيه الآيدي
        window.onload = function() {
            const urlParams = new URLSearchParams(window.location.search);
            const openModalId = urlParams.get('open');
            if (openModalId) {
                const targetModal = document.getElementById('modal_profile_' + openModalId);
                if (targetModal) {
                    targetModal.style.display = 'block';
                }
            }
        };
    </script>
</body>
</html>