<!DOCTYPE html>
<html lang="ar">
<head>
    <meta charset="UTF-8">
    <title>ملف العسكري | <%= member.realName %></title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <%- include('partials/navbar') %>
    
    <% 
        // استدعاء العهدة الخاصة بهذا العسكري فقط
        const memberWeapons = (custody.weaponLogs || []).map((l, i) => ({...l, originalIndex: i})).filter(l => l.receiverDiscordId === member.id);
        const memberVehicles = (custody.vehicleLogs || []).map((l, i) => ({...l, originalIndex: i})).filter(l => l.receiverDiscordId === member.id);
    %>

    <div class="container fade-in" style="max-width: 900px;">
        <a href="/system/personnel" class="btn-secondary" style="margin-bottom: 20px; display: inline-block;">⬅️ العودة لسجل الأفراد</a>
        
        <div class="card" style="border-top-color: var(--primary);">
            
            <div style="text-align:center; padding-bottom: 20px; margin-bottom:25px; border-bottom: 1px solid var(--border);">
                <h2 class="header-title" style="border:none; background:transparent; margin-bottom:10px;">🗂️ ملف العسكري: <span style="color:var(--warning);"><%= member.realName %></span></h2>
                <div style="display:flex; justify-content:center; gap:10px; flex-wrap:wrap;">
                    <span style="background: rgba(37, 184, 100, 0.12); border: 1px solid var(--success); padding: 5px 15px; border-radius: 8px; color: var(--success); font-weight: bold; font-size: 13px;">📅 انضمام: <%= member.joinDate || 'قديم' %></span>
                    <span style="background: rgba(140, 116, 255, 0.12); border: 1px solid var(--special); padding: 5px 15px; border-radius: 8px; color: var(--special); font-weight: bold; font-size: 13px;">🕒 آخر دخول: <%= member.lastLogin || 'غير معروف' %></span>
                </div>
            </div>
            
            <div class="profile-section section-purple">
                <h3 style="color: var(--special);">🎖️ الشهادات والرخص الحاصل عليها</h3>
                <% if(!member.certs || member.certs.length === 0) { %>
                    <p style="color:var(--text-muted); font-size:13px; margin-bottom: 15px;">لا توجد شهادات مسجلة لهذا العسكري.</p>
                <% } else { %>
                    <div style="display:flex; gap:10px; flex-wrap:wrap; margin-bottom: 20px;">
                        <% member.certs.forEach(cId => { %>
                            <div style="background: rgba(140, 116, 255, 0.1); border: 1px solid var(--special); padding: 6px 12px; border-radius: 8px; display: flex; align-items: center; gap: 10px; font-size: 12px; font-weight: bold;">
                                <span style="color: white;"><%= certTypes[cId] ? certTypes[cId].name : cId %></span>
                                <form action="/system/personnel/revoke-cert" method="POST" onsubmit="return confirm('سحب الشهادة؟');" style="margin:0;">
                                    <input type="hidden" name="targetId" value="<%= member.id %>"><input type="hidden" name="certId" value="<%= cId %>">
                                    <button class="btn-danger" style="padding: 4px 8px; font-size: 11px; border-radius:4px; border:none;">سحب ❌</button>
                                </form>
                            </div>
                        <% }) %>
                    </div>
                <% } %>
                
                <div style="background: rgba(255,255,255,0.02); padding: 15px; border-radius: 8px; border: 1px solid var(--border);">
                    <span style="color:var(--text-muted); font-size:12px; font-weight:bold; display:block; margin-bottom:8px;">منح شهادة استثنائية (مباشرة)</span>
                    <form action="/system/personnel/grant-cert-direct" method="POST" style="display:flex; gap:10px; margin:0;">
                        <input type="hidden" name="targetId" value="<%= member.id %>">
                        <select name="certId" required class="form-control" style="flex:1; margin:0;">
                            <option value="" disabled selected>-- اختر شهادة --</option>
                            <% Object.entries(certTypes).forEach(([cId, cInfo]) => { %> <option value="<%= cId %>"><%= cInfo.name %></option> <% }) %>
                        </select>
                        <button type="submit" class="btn-success" onclick="return confirm('تأكيد المنح؟');">منح 📜</button>
                    </form>
                </div>
            </div>

            <div class="profile-section section-red">
                <h3 style="color: var(--danger);">⚙️ الإجراءات الإدارية والترقيات</h3>
                
                <div style="background: rgba(255,255,255,0.02); padding: 15px; border-radius: 8px; border: 1px solid var(--border); margin-bottom: 15px;">
                    <span style="color:var(--text-muted); font-size:12px; font-weight:bold; display:block; margin-bottom:8px;">شريحة الديسكورد</span>
                    <form action="/system/personnel/action" method="POST" style="display:flex; gap:8px; margin:0;">
                        <input type="hidden" name="targetId" value="<%= member.id %>"><input type="hidden" name="action" value="update_discord">
                        <select name="newDiscordRole" class="form-control" style="margin:0;">
                            <option value="enlisted" <%= member.discordRank === 'أفراد' ? 'selected' : '' %>>أفراد</option>
                            <option value="nco" <%= member.discordRank === 'ضباط صف' ? 'selected' : '' %>>ضباط صف</option>
                            <option value="officer" <%= member.discordRank === 'ضباط' ? 'selected' : '' %>>ضباط</option>
                        </select>
                        <button class="btn-primary">حفظ</button>
                    </form>
                </div>

                <div style="background: rgba(255,255,255,0.02); padding: 15px; border-radius: 8px; border: 1px solid var(--border); margin-bottom: 15px;">
                    <span style="color:var(--text-muted); font-size:12px; font-weight:bold; display:block; margin-bottom:8px;">تحديث بيانات النظام والرتبة العسكرية</span>
                    <form action="/system/personnel/action" method="POST">
                        <input type="hidden" name="targetId" value="<%= member.id %>"><input type="hidden" name="action" value="update_site">
                        <div style="display:grid; grid-template-columns:1fr 1fr 1fr; gap:10px; margin-bottom: 10px;">
                            <input type="text" name="newRealName" value="<%= member.realName %>" placeholder="الاسم الثنائي" required class="form-control" style="margin:0;">
                            <input type="text" name="newNationalId" value="<%= member.nationalId %>" placeholder="الرقم الوطني" required class="form-control" style="margin:0;">
                            <select name="newSiteRank" class="form-control" style="margin:0;">
                                <% RANKS_LADDER.forEach(rank => { %><option value="<%= rank %>" <%= member.siteRank === rank ? 'selected' : '' %>><%= rank %></option><% }) %>
                            </select>
                        </div>
                        <button class="btn-warning" style="width:100%;">حفظ بيانات النظام 💾</button>
                    </form>
                </div>

                <form id="fireForm" action="/system/personnel/action" method="POST">
                    <input type="hidden" name="targetId" value="<%= member.id %>"><input type="hidden" name="action" value="fire"><input type="hidden" name="reason" id="fireReason">
                    <button type="button" class="btn-danger" style="width:100%;" onclick="firePersonnel()">فصل وطي قيد من القطاع ❌</button>
                </form>
            </div>

            <div class="profile-section section-blue" style="margin-bottom: 0;">
                <h3 style="color: var(--primary);">📦 صرف واسترجاع العهدة</h3>
                
                <div style="display:grid; grid-template-columns:1fr 1fr; gap:15px;">
                    <div style="background: rgba(255,255,255,0.02); padding: 15px; border-radius: 8px; border: 1px solid var(--border);">
                        <h4 style="color:var(--primary); margin-bottom:15px; font-size:14px; text-align:center;">🔫 صرف سلاح</h4>
                        <form action="/custody/weapons/issue" method="POST">
                            <input type="hidden" name="discordId" value="<%= member.id %>"><input type="hidden" name="receiverName" value="<%= member.realName %>"><input type="hidden" name="nationalId" value="<%= member.nationalId %>">
                            <select name="weaponType" required class="form-control" style="margin-bottom:10px;">
                                <option value="" disabled selected>-- اختر السلاح --</option>
                                <% (custody.weaponTypes || []).forEach(type => { %> <option value="<%= type %>"><%= type %></option> <% }) %>
                            </select>
                            <div style="display:flex; gap:8px;">
                                <input type="text" name="serialNumber" required placeholder="السيريال (S/N)" class="form-control" style="flex:1; direction:ltr; font-family:monospace; margin:0;">
                                <button class="btn-primary" style="margin:0;">صرف</button>
                            </div>
                        </form>
                    </div>
                    
                    <div style="background: rgba(255,255,255,0.02); padding: 15px; border-radius: 8px; border: 1px solid var(--border);">
                        <h4 style="color:var(--warning); margin-bottom:15px; font-size:14px; text-align:center;">🚓 صرف مركبة</h4>
                        <form action="/custody/vehicles/issue" method="POST">
                            <input type="hidden" name="discordId" value="<%= member.id %>"><input type="hidden" name="receiverName" value="<%= member.realName %>"><input type="hidden" name="nationalId" value="<%= member.nationalId %>">
                            <select name="vehicleType" required class="form-control" style="margin-bottom:10px;">
                                <option value="" disabled selected>-- اختر المركبة --</option>
                                <% (custody.vehicleTypes || []).forEach(type => { %> <option value="<%= type %>"><%= type %></option> <% }) %>
                            </select>
                            <div style="display:flex; gap:8px;">
                                <input type="text" name="plateNumber" required placeholder="رقم اللوحة" class="form-control" style="flex:1; direction:ltr; font-family:monospace; margin:0;">
                                <button class="btn-warning" style="margin:0;">صرف</button>
                            </div>
                        </form>
                    </div>
                </div>

                <div style="margin-top: 20px;">
                    <span style="color:var(--text-muted); font-size:13px; font-weight:bold; display:block; margin-bottom:10px;">📋 العهدة المسجلة حالياً:</span>
                    <% if(memberWeapons.length === 0 && memberVehicles.length === 0) { %>
                        <p style="color:var(--text-muted); font-size:13px; text-align:center; padding: 15px; background: rgba(255,255,255,0.02); border-radius: 8px; border: 1px solid var(--border);">لا توجد عهدة مسجلة.</p>
                    <% } else { %>
                        <table style="width:100%; border-collapse: collapse; border: 1px solid var(--border); border-radius: 8px; overflow: hidden;">
                            <% memberWeapons.forEach(w => { %>
                                <tr style="border-bottom: 1px solid var(--border);">
                                    <td style="color:white; padding: 12px; font-size:13px; background: rgba(255,255,255,0.015);">🔫 <%= w.weaponType %> <br><span style="color:var(--text-muted); font-family: monospace;">S/N: <%= w.serialNumber %></span></td>
                                    <td style="text-align:left; padding: 12px; background: rgba(255,255,255,0.015);">
                                        <form action="/system/custody/return" method="POST" onsubmit="return confirm('تأكيد سحب السلاح؟');" style="margin:0;">
                                            <input type="hidden" name="type" value="weapon"><input type="hidden" name="index" value="<%= w.originalIndex %>"><input type="hidden" name="redirect" value="/system/personnel/<%= member.id %>">
                                            <button class="btn-secondary" style="padding:6px 12px; font-size:12px;">استرجاع</button>
                                        </form>
                                    </td>
                                </tr>
                            <% }) %>
                            <% memberVehicles.forEach(v => { %>
                                <tr style="border-bottom: 1px solid var(--border);">
                                    <td style="color:white; padding: 12px; font-size:13px; background: rgba(255,255,255,0.015);">🚓 <%= v.vehicleType %> <br><span style="color:var(--text-muted); font-family: monospace;">لوحة: <%= v.plateNumber %></span></td>
                                    <td style="text-align:left; padding: 12px; background: rgba(255,255,255,0.015);">
                                        <form action="/system/custody/return" method="POST" onsubmit="return confirm('تأكيد سحب المركبة؟');" style="margin:0;">
                                            <input type="hidden" name="type" value="vehicle"><input type="hidden" name="index" value="<%= v.originalIndex %>"><input type="hidden" name="redirect" value="/system/personnel/<%= member.id %>">
                                            <button class="btn-secondary" style="padding:6px 12px; font-size:12px;">استرجاع</button>
                                        </form>
                                    </td>
                                </tr>
                            <% }) %>
                        </table>
                    <% } %>
                </div>
            </div>

        </div>
    </div>

    <script>
        function firePersonnel() { 
            let reason = prompt('الرجاء كتابة سبب الفصل لإضافته في السجل الشامل:'); 
            if(reason !== null && reason.trim() !== "") { 
                document.getElementById('fireReason').value = reason; 
                document.getElementById('fireForm').submit(); 
            } 
        }
    </script>
</body>
</html>