<!DOCTYPE html>
<html lang="ar">
<head>
    <meta charset="UTF-8">
    <title>بوابة التجنيد - وزارة الداخلية</title>
    <link rel="stylesheet" href="/style.css?v=9">
    <style>
        .form-step { display: none; }
        .form-step.active { display: block; animation: fadeIn 0.5s; }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .input-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 15px;
            margin-bottom: 20px;
        }

        .form-input {
            width: 100%;
            padding: 12px;
            background: rgba(0,0,0,0.5);
            border: 1px solid var(--primary);
            color: white;
            border-radius: 8px;
            box-sizing: border-box;
        }

        .form-label {
            color: var(--primary);
            font-size: 14px;
            margin-bottom: 5px;
            display: block;
            font-weight: bold;
        }

        @media (max-width: 900px) {
            .input-grid { grid-template-columns: 1fr; }
        }
    </style>
</head>
<body>
<%- include('partials/navbar') %>

<div class="container fade-in" style="text-align:center;">
    <h1 style="color: var(--primary); font-weight:900;">| بوابة التجنيد العسكري |</h1>
    <hr style="border-color: var(--border); width:50%; margin:10px auto 30px;">

    <div class="card" style="text-align:right; border-right:5px solid var(--primary);">
        <h2 style="color: var(--primary);">📜 شروط التقديم</h2>
        <p>> العمر 18 سنة فما فوق</p>
        <p>> مايك ممتاز وغير مزعج</p>
        <p>> بدون سجل إجرامي</p>
    </div>

    <div style="margin-top:40px;">

        <% if (!appsOpen) { %>
            <div class="card" style="border-color:var(--danger);">
                <h2 style="color:var(--danger);">التقديم مغلق حالياً</h2>
            </div>

        <% } else if (!user.perms.isActivated) { %>
            <div class="card" style="border-color:var(--danger);">
                <h2 style="color:var(--danger);">⚠️ أنت غير مفعل</h2>
                <p>لا يمكنك التقديم لأن حسابك غير مفعل.</p>
            </div>

        <% } else { %>

            <button id="startBtn"
                class="btn-success"
                style="font-size:20px; padding:20px 50px;"
                onclick="document.getElementById('apply-form').style.display='block'; this.style.display='none'">
                بدء نموذج التجنيد
            </button>

            <div id="apply-form" style="display:none; margin-top:40px; text-align:right;">
                <form action="/submit" method="POST" class="card" style="border-color:var(--success);">

                    <div id="step1" class="form-step active">
                        <h2 style="color:var(--success); text-align:center;">الخطوة 1: البيانات الشخصية</h2>

                        <div class="input-grid">
                            <div>
                                <label class="form-label">الاسم الثنائي</label>
                                <input name="realName" class="form-input" required>
                            </div>

                            <div>
                                <label class="form-label">رقم الهوية</label>
                                <input name="nationalId" class="form-input" required>
                            </div>

                            <div>
                                <label class="form-label">آيدي ديسكورد</label>
                                <input class="form-input" value="<%= user.id %>" readonly>
                            </div>

                            <div>
                                <label class="form-label">العمر</label>
                                <input name="age" class="form-input" required>
                            </div>
                        </div>

                        <button type="button" class="btn-primary" onclick="nextStep()">التالي</button>
                    </div>

                    <div id="step2" class="form-step">
                        <h2 style="color:var(--success); text-align:center;">الخطوة 2: الأسئلة</h2>

                        <% questions.forEach((q,i)=>{ %>
                            <label class="form-label"><%= i+1 %>. <%= q.label %></label>
                            <textarea name="q_<%= i %>" class="form-input" required></textarea>
                        <% }) %>

                        <div style="margin-top:20px;">
                            <button type="button" class="btn-secondary" onclick="prevStep()">رجوع</button>
                            <button type="submit" class="btn-success">إرسال</button>
                        </div>
                    </div>

                </form>
            </div>

        <% } %>

    </div>
</div>

<script>
function nextStep(){
    document.getElementById('step1').classList.remove('active');
    document.getElementById('step2').classList.add('active');
}
function prevStep(){
    document.getElementById('step2').classList.remove('active');
    document.getElementById('step1').classList.add('active');
}
</script>

</body>
</html>